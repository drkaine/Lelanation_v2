{
  "name": "lelanation-v2",
  "version": "0.13.0",
  "private": true,
  "workspaces": [
    "frontend",
    "backend",
    "companion-app",
    "packages/*"
  ],
  "overrides": {
    "serialize-javascript": "7.0.4",
    "minimatch": "9.0.7"
  },
  "scripts": {
    "prepare": "husky",
    "sync:data": "cd backend && npm run sync:data",
    "data-enrich:cycle": "cd backend && npm run script:data-enrich-cycle",
    "exe-windows": "powershell -NoProfile -ExecutionPolicy Bypass -File ./scripts/exe-windows.ps1"
  },
  "devDependencies": {
    "husky": "^9.0.0",
    "lint-staged": "^15.0.0",
    "prisma": "^6.19.2"
  },
  "dependencies": {
    "@prisma/client": "^6.19.2"
  }
}
