# Core
ENV=dev
DATABASE_URL=postgresql://lelanation:lelanation@localhost:5434/lelanation_statistiques
REDIS_URL=redis://127.0.0.1:6379
RIOT_API_KEY=RGAPI-your-key-here
API_KEY_TYPE=personal

# Gateway — floor for PollerTuner; auto-ratchets up on 429 (see TUNER_RATCHET_*)
SAFETY_MARGIN=0.08

# Tuner ratchet (optional overrides)
TUNER_RATCHET_STEP=0.02
TUNER_RATCHET_MAX=0.20
TUNER_RATCHET_DECAY=10

# Dynamic sinceTimestamp (SinceTimestampResolver)
# prod_full_history mode: fetch match IDs since this UTC date when all players polled within 24h
FULL_HISTORY_SINCE_DATE=2026-01-08

# Poller (src/main.ts)
POLLER_SINCE_DAYS=14
POLLER_MATCH_IDS_PER_PAGE=100
POLLER_RESOLVE_PARTICIPANT_RANKS=true
# Purge processed_matches / player_rank_history : false (défaut) | true (5 j) | <jours>
# POLLER_PATCH_RETENTION_DAYS=false

# PollerTuner (auto batch + concurrency from gateway rate limits)
TUNER_WARMUP_SESSIONS=5
TUNER_SESSION_DURATION_S=30
TUNER_EMA_ALPHA=0.3

# Session pool (replaces sequential discovery sleeps)
MAX_PLAYERS_PER_SESSION=500
PLAYER_QUEUE_REFILL_POLL_MS=2000
PERSONAL_TARGET_UTILIZATION_PCT=95
# Personal pipeline — max 2 concurrent sessions; queue guard prevents 18-22s match latency
PERSONAL_MAX_CONCURRENT_SESSIONS=2
MAX_GATEWAY_QUEUE=10
PERSONAL_MAX_CONCURRENT_PLAYERS=2
PERSONAL_MAX_CONCURRENT_MATCH_FETCHES=4
PERSONAL_MAX_PARTICIPANT_RANK_CONCURRENCY=2

# Backpressure
BACKPRESSURE_THRESHOLD=500
BACKPRESSURE_POLL_INTERVAL_MS=5000

# Observability
OBSERVABILITY_SNAPSHOT_PATH=./poller-observability.json
LIVE_TOKEN_DISPLAY_INTERVAL_MS=5000
DB_SLOW_THRESHOLD_MS=1000
POLL_STALL_THRESHOLD_MS=300000

# Live tests
TEST_PUUID=
POLLER_LIVE_SINCE_DAYS=2
POLLER_LIVE_MAX_MATCHES=2
