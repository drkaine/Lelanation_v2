# Environnement
ENV=dev

# Server
PORT=3500
POLLER_EXTERNAL=1

# Redis
REDIS_URL=redis://localhost:6379

# PostgreSQL — base unique stats (Drizzle, docker compose postgres-statistiques, port 5434)
DATABASE_URL=postgresql://lelanation:lelanation@localhost:5434/lelanation_statistiques

# Riot API (requis pour le poller; peut ensuite etre gere via l'admin)
RIOT_API_KEY=RGAPI-xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Optionnel
REDIS_TEST_URL=redis://localhost:6380
LOG_LEVEL=info

# Version de clé pour les PUUIDs (dev|perso|prod)
# PLAYER_KEY_VERSION=dev
