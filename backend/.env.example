# Core
ENV=dev
DATABASE_URL=postgresql://lelanation:lelanation@localhost:5434/lelanation_statistiques
REDIS_URL=redis://127.0.0.1:6379
RIOT_API_KEY=RGAPI-your-key-here
API_KEY_TYPE=personal

# Gateway
SAFETY_MARGIN=0.05

# Poller (src/main.ts)
POLLER_SINCE_DAYS=14
POLLER_MATCH_IDS_PER_PAGE=100
POLLER_RESOLVE_PARTICIPANT_RANKS=true

# PollerTuner (auto batch + concurrency from gateway rate limits)
TUNER_WARMUP_SESSIONS=5
TUNER_SESSION_DURATION_S=30
TUNER_EMA_ALPHA=0.3

# Discovery / backpressure
DISCOVERY_IDLE_SLEEP_MS=30000
BACKPRESSURE_THRESHOLD=500
BACKPRESSURE_POLL_INTERVAL_MS=5000

# Observability
OBSERVABILITY_SNAPSHOT_PATH=./poller-observability.json
LIVE_TOKEN_DISPLAY_INTERVAL_MS=5000
DB_SLOW_THRESHOLD_MS=1000
POLL_STALL_THRESHOLD_MS=300000

# Live tests
TEST_PUUID=
POLLER_LIVE_SINCE_DAYS=2
POLLER_LIVE_MAX_MATCHES=2
