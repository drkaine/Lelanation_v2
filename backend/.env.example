# Server
PORT=3500
POLLER_EXTERNAL=1

# Database (PostgreSQL) — utilisé pour les stats LoL (matches, participants)
# Avec Docker : docker compose up -d puis DATABASE_URL ci-dessous
# Format standard requis par @prisma/adapter-pg
# Port 5432 si PostgreSQL local ; 5433 si Docker (docker compose up -d)
DATABASE_URL="postgresql://lelanation:lelanation@localhost:5433/lelanation_stats"

# Base « lelanation » (schéma backend/prisma2/) — requise pour npm run prisma2:migrate / prisma2:generate
# Créer la base : CREATE DATABASE lelanation; puis définir l’URL (même host/user, DB=lelanation)
# DATABASE_URL_LELANATION="postgresql://lelanation:lelanation@localhost:5433/lelanation"
# Connexions Prisma par process (défaut 5). Réduire si "too many clients" avec backend + worker + scripts.
# PRISMA_POOL_MAX=5

# Riot API (optionnel : peut être défini dans l’admin, onglet Clé API Riot)
# RIOT_API_KEY=RGAPI-...
# Délai (ms) avant de lancer le poller au démarrage du backend uniquement — défaut 120000 (2 min). 0 = pas de délai.
# RIOT_POLLER_STARTUP_DELAY_MS=120000

# Version de clé pour les PUUIDs (dev|perso|prod). Utilisé par riot:migrate-puuid et la collecte.
# Permet de savoir quelle clé Riot est associée aux PUUIDs en DB et d'éviter de re-fetcher les matchs déjà migrés.
# RIOT_PUUID_KEY_VERSION=prod

# Snapshot quotidien champion x tier (WR, pick, bans) — 1er run après cette heure UTC ; désactiver avec CHAMPION_TIER_SNAPSHOT_DISABLED=1
# CHAMPION_TIER_SNAPSHOT_UTC_HOUR=0
# CHAMPION_TIER_SNAPSHOT_UTC_MINUTE=5
# CHAMPION_TIER_SNAPSHOT_DISABLED=1
# Pause le poller pendant le backfill global pour limiter les deadlocks/contentions.
# BACKFILL_AGG_PAUSE_POLLER=1

# Riot match collect – si l’API renvoie 500 en masse, mettre RIOT_5XX_MAX_RETRIES=0
# RIOT_5XX_MAX_RETRIES=0
# Normal mode: budget requêtes/cycle (100/2 min), délai 2 min. RIOT_MATCH_IDS_PER_SUMMONER=20 par défaut.
# RIOT_MATCH_REQUEST_BUDGET=95
# RIOT_MATCH_CYCLE_DELAY_MS=120000
# Sécurité anti-429: si remaining <= 1 (99/100), appliquer une micro-pause
# RIOT_APP_120S_BREATH_REMAINING_MAX=1
# Durée et cadence de cette pause near-limit (ms)
# RIOT_APP_120S_BREATH_MS=12000
# RIOT_APP_120S_BREATH_MIN_INTERVAL_MS=1500
# Hard stop piloté par headers (arrêt net quand remaining<=N sur la fenêtre 120s)
# RIOT_APP_120S_HARD_STOP_REMAINING_MAX=1
# RIOT_APP_120S_HARD_STOP_MS=45000
# Espacement min entre deux requêtes sortantes (ms) — défaut 50 (= plafond 20 req/s sur le bucket 1 s Riot).
# Une valeur > 50 (ex. 110) réduit les pics `AppCount` dans la fenêtre 120 s sans gagner en marge 429.
# RIOT_LIMITER_MIN_TIME_MS=50
# Débit cible sur la fenêtre app 120 s (max 100). Monter vers 96–98 si tu veux coller au plafond Riot sans hard-stop agressif.
# RIOT_APP_TARGET_PER_120S=98
# Après un 429, forcer temporairement le fetch de matchs en mode séquentiel (ms)
# RIOT_POST_429_SERIAL_MODE_MS=120000
# Logs unifiés [rate_limit] (en-têtes Riot sur chaque ~2 min) — désactivé par défaut ; mettre =1 pour activer
# RIOT_RATE_LIMIT_UNIFIED_LOG=1
# Limite de parallélisme pour la phase "match ids by puuid" (anti-burst 429 league-v4)
# RIOT_MATCH_IDS_LOOKUP_CONCURRENCY=6
# Taille du lot de joueurs scannés par boucle poller (défaut 150)
# POLLER_PLAYERS_PER_LOOP=500
# Raw queue recovery (après reboot/SIGINT): requeue des lignes bloquées en "processing"
# RAW_INGEST_STALE_PROCESSING_MAX_AGE_MS=600000
# RAW_INGEST_STALE_PROCESSING_REQUEUE_BATCH=500
# match_ingest_raw: succès extract-and-burn supprime la ligne tout de suite (JSON non conservé).
# Purge périodique des lignes encore en "done" (legacy / ancien code) — défaut rétention 12 h, intervalle 12 h
# RAW_INGEST_DONE_RETENTION_MS=43200000
# RAW_INGEST_DONE_CLEANUP_INTERVAL_MS=43200000
# RAW_INGEST_DONE_CLEANUP_BATCH=50000
# Ingest throughput mode: 0 = pas de lookup league-v4 pendant l'insert (débit DB max), 1 = enrichissement rank en ligne
# MATCH_INGEST_LEAGUE_LOOKUPS=0
# Force un appel league-v4 pour chaque participant de chaque match ingéré (ignore le cache rank)
# MATCH_INGEST_FORCE_LEAGUE_LOOKUP_EACH_PARTICIPANT=1
# Pipeline rank décorrélé (recommandé): refresh league-v4 asynchrone via file prioritaire PUUID
# MATCH_ASYNC_PRIORITY_RANK_REFRESH=1
# MATCH_ASYNC_PRIORITY_RANK_REFRESH_PER_LOOP=40
# MATCH_ASYNC_PRIORITY_RANK_REFRESH_CONCURRENCY=4
# Récup automatique de la file "match-ingest-queue/":
# - renomme les .abort.*.json orphelins en .json (requeue),
# - requeue les .processing.*.json dont mtime > MAX_AGE (worker mort).
# MATCH_INGEST_FILE_QUEUE_RECOVERY_INTERVAL_MS=60000
# MATCH_INGEST_FILE_QUEUE_STALE_PROCESSING_MAX_AGE_MS=600000
# Admin (Basic Auth)
# ADMIN_USER_NAME=...
# ADMIN_PASSWORD=...

# Après sauvegarde de la clé API Riot en admin : build backend + pm2 restart (nom de l’app PM2)
# PM2_APP_NAME=lelanation-backend

# Optionnel : Discord, YouTube, etc.
# DISCORD_WEBHOOK_URL=...
# YOUTUBE_API_KEY=...
# Vérification de santé des liens sociaux de la home (UTC)
# SOCIAL_LINKS_HEALTHCHECK_CRON="0 */6 * * *"
# SOCIAL_LINKS_HEALTHCHECK_DISABLED=1

# Companion app download (admin route /api/admin/app-download)
# Option 1 (recommended): "latest" URL — always points to the most recent release, no update needed
COMPANION_APP_DOWNLOAD_URL=https://github.com/drkaine/Lelanation_v2/releases/latest/download/Lelanation.exe
# Option 2: pin to a specific tag
# COMPANION_APP_DOWNLOAD_URL=https://github.com/drkaine/Lelanation_v2/releases/download/v0.1.0/Lelanation.exe
# Option 3: local file path served by backend (absolute or relative to backend/)
# COMPANION_APP_INSTALLER_PATH=/home/ubuntu/dev/Lelanation_v2/installer/Lelanation.exe
