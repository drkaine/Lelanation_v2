// Lelanation stats: matches and participants (Ranked Solo/Duo, EUW/EUNE)
// See epic-lol-statistics-platform.md

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Niveau match: champs légers. Team data (bans/objectives) est normalisée dans match_teams/bans.
model Match {
  id                       BigInt   @id @default(autoincrement())
  matchId                  String   @unique @map("match_id")
  gameVersion              String?  @map("game_version")
  gameDuration             Int?     @map("game_duration")
  platformId               String?  @map("platform_id")
  rank                     String?  // average rank of players in the match, e.g. "GOLD_II"
  gameEndedInSurrender     Boolean? @map("game_ended_in_surrender")
  gameEndedInEarlySurrender Boolean? @map("game_ended_in_early_surrender")
  createdAt                DateTime @default(now()) @map("created_at")

  participants Participant[]
  matchTeams   MatchTeam[]

  @@map("matches")
}

// Participant: colonnes indexées pour agrégations.
model Participant {
  id                          BigInt   @id @default(autoincrement())
  playerId                    BigInt   @map("player_id")
  matchId                     BigInt   @map("match_id")
  teamId                      Int?     @map("team_id") // 100 = blue, 200 = red (Riot API)
  championId                  Int      @map("champion_id")
  role                        String?  // TOP, JUNGLE, MIDDLE, BOTTOM, SUPPORT
  rankTier                    String?  @map("rank_tier")
  rankDivision                String?  @map("rank_division")
  rankLp                      Int?     @map("rank_lp")
  kills                       Int      @default(0)
  deaths                      Int      @default(0)
  assists                     Int      @default(0)
  champLevel                  Int?     @map("champ_level")
  goldEarned                  Int?     @map("gold_earned")
  totalDamageDealtToChampions Int?     @map("total_damage_dealt_to_champions")
  totalMinionsKilled          Int?     @map("total_minions_killed")
  visionScore                 Int?     @map("vision_score")
  baronKills                  Int?     @map("baron_kills")
  consumablesPurchased        Int?     @map("consumables_purchased")
  damageDealtToBuildings      Int?     @map("damage_dealt_to_buildings")
  damageDealtToEpicMonsters   Int?     @map("damage_dealt_to_epic_monsters")
  damageDealtToObjectives     Int?     @map("damage_dealt_to_objectives")
  damageDealtToTurrets        Int?     @map("damage_dealt_to_turrets")
  damageSelfMitigated         Int?     @map("damage_self_mitigated")
  doubleKills                 Int?     @map("double_kills")
  dragonKills                 Int?     @map("dragon_kills")
  goldSpent                   Int?     @map("gold_spent")
  inhibitorKills              Int?     @map("inhibitor_kills")
  inhibitorTakedowns          Int?     @map("inhibitor_takedowns")
  inhibitorsLost              Int?     @map("inhibitors_lost")
  itemsPurchased              Int?     @map("items_purchased")
  killingSprees               Int?     @map("killing_sprees")
  largestCriticalStrike       Int?     @map("largest_critical_strike")
  largestKillingSpree         Int?     @map("largest_killing_spree")
  largestMultiKill            Int?     @map("largest_multi_kill")
  longestTimeSpentLiving      Int?     @map("longest_time_spent_living")
  magicDamageDealt            Int?     @map("magic_damage_dealt")
  magicDamageDealtToChampions Int?     @map("magic_damage_dealt_to_champions")
  magicDamageTaken            Int?     @map("magic_damage_taken")
  neutralMinionsKilled        Int?     @map("neutral_minions_killed")
  objectivesStolen            Int?     @map("objectives_stolen")
  objectivesStolenAssists     Int?     @map("objectives_stolen_assists")
  pentaKills                  Int?     @map("penta_kills")
  physicalDamageDealt         Int?     @map("physical_damage_dealt")
  physicalDamageDealtToChampions Int?  @map("physical_damage_dealt_to_champions")
  physicalDamageTaken         Int?     @map("physical_damage_taken")
  placement                   Int?     @map("placement")
  quadraKills                 Int?     @map("quadra_kills")
  roleBoundItem               Int?     @map("role_bound_item")
  sightWardsBoughtInGame      Int?     @map("sight_wards_bought_in_game")
  timeCCingOthers             Int?     @map("time_ccing_others")
  totalAllyJungleMinionsKilled Int?    @map("total_ally_jungle_minions_killed")
  totalDamageDealt            Int?     @map("total_damage_dealt")
  totalDamageShieldedOnTeammates Int?  @map("total_damage_shielded_on_teammates")
  totalDamageTaken            Int?     @map("total_damage_taken")
  totalEnemyJungleMinionsKilled Int?   @map("total_enemy_jungle_minions_killed")
  totalHeal                   Int?     @map("total_heal")
  totalHealsOnTeammates       Int?     @map("total_heals_on_teammates")
  totalTimeCCDealt            Int?     @map("total_time_cc_dealt")
  totalTimeSpentDead          Int?     @map("total_time_spent_dead")
  totalUnitsHealed            Int?     @map("total_units_healed")
  tripleKills                 Int?     @map("triple_kills")
  trueDamageDealt             Int?     @map("true_damage_dealt")
  trueDamageDealtToChampions  Int?     @map("true_damage_dealt_to_champions")
  trueDamageTaken             Int?     @map("true_damage_taken")
  turretKills                 Int?     @map("turret_kills")
  turretTakedowns             Int?     @map("turret_takedowns")
  turretsLost                 Int?     @map("turrets_lost")
  unrealKills                 Int?     @map("unreal_kills")
  visionWardsBoughtInGame     Int?     @map("vision_wards_bought_in_game")
  wardsKilled                 Int?     @map("wards_killed")
  wardsPlaced                 Int?     @map("wards_placed")
  spell1Casts                 Int?     @map("spell1_casts")
  spell2Casts                 Int?     @map("spell2_casts")
  spell3Casts                 Int?     @map("spell3_casts")
  spell4Casts                 Int?     @map("spell4_casts")
  summoner1Casts              Int?     @map("summoner1_casts")
  summoner2Casts              Int?     @map("summoner2_casts")
  statPerks                   Json?    @map("stat_perks")
  items                       Json?
  runes                       Json?
  summonerSpells              Json?    @map("summoner_spells")
  challenges                  Json?
  // Challenge values: one column per allowlisted key
  challengeSoloKills                       Float? @map("ch_solo_kills")
  challengeTakedowns                       Float? @map("ch_takedowns")
  challengeBountyGold                     Float? @map("ch_bounty_gold")
  challengeDoubleAces                     Float? @map("ch_double_aces")
  challengeBuffsStolen                    Float? @map("ch_buffs_stolen")
  challengeFlawlessAces                   Float? @map("ch_flawless_aces")
  challengeHadOpenNexus                   Float? @map("ch_had_open_nexus")
  challengeQuickCleanse                   Float? @map("ch_quick_cleanse")
  challengeSnowballsHit                   Float? @map("ch_snowballs_hit")
  challengeWardsGuarded                   Float? @map("ch_wards_guarded")
  challengeEarliestBaron                  Float? @map("ch_earliest_baron")
  challengeSkillshotsHit                  Float? @map("ch_skillshots_hit")
  challengeUnseenRecalls                  Float? @map("ch_unseen_recalls")
  challengeMaxKillDeficit                 Float? @map("ch_max_kill_deficit")
  challengeQuickSoloKills                 Float? @map("ch_quick_solo_kills")
  challengeSoloBaronKills                 Float? @map("ch_solo_baron_kills")
  challengeVoidMonsterKill                Float? @map("ch_void_monster_kill")
  challengeFullTeamTakedown               Float? @map("ch_full_team_takedown")
  challengeInitialBuffCount              Float? @map("ch_initial_buff_count")
  challengeInitialCrabCount               Float? @map("ch_initial_crab_count")
  challengeOutnumberedKills               Float? @map("ch_outnumbered_kills")
  challengePickKillWithAlly               Float? @map("ch_pick_kill_with_ally")
  challengeQuickFirstTurret              Float? @map("ch_quick_first_turret")
  challengeScuttleCrabKills               Float? @map("ch_scuttle_crab_kills")
  challengeSkillshotsDodged              Float? @map("ch_skillshots_dodged")
  challengeMultiKillOneSpell              Float? @map("ch_multi_kill_one_spell")
  challengeSaveAllyFromDeath             Float? @map("ch_save_ally_from_death")
  challengeTakedownsInAlcove             Float? @map("ch_takedowns_in_alcove")
  challengeTurretPlatesTaken             Float? @map("ch_turret_plates_taken")
  challengeHealFromMapSources            Float? @map("ch_heal_from_map_sources")
  challenge12AssistStreakCount           Float? @map("ch_12_assist_streak_count")
  challengeInfernalScalePickup           Float? @map("ch_infernal_scale_pickup")
  challengeAcesBefore15Minutes           Float? @map("ch_aces_before_15_minutes")
  challengeDeathsByEnemyChamps           Float? @map("ch_deaths_by_enemy_champs")
  challengeKillsUnderOwnTurret           Float? @map("ch_kills_under_own_turret")
  challengeRiftHeraldTakedowns           Float? @map("ch_rift_herald_takedowns")
  challengeTeamRiftHeraldKills           Float? @map("ch_team_rift_herald_kills")
  challengeKillsNearEnemyTurret          Float? @map("ch_kills_near_enemy_turret")
  challengeTeamElderDragonKills          Float? @map("ch_team_elder_dragon_kills")
  challengeElderDragonMultikills         Float? @map("ch_elder_dragon_multikills")
  challengeFirstTurretKilledTime        Float? @map("ch_first_turret_killed_time")
  challengeFistBumpParticipation         Float? @map("ch_fist_bump_participation")
  challengeMejaisFullStackInTime         Float? @map("ch_mejais_full_stack_in_time")
  challengeTakedownOnFirstTurret         Float? @map("ch_takedown_on_first_turret")
  challengeTakedownsFirstXMinutes        Float? @map("ch_takedowns_first_x_minutes")
  challengeWardTakedownsBefore20M        Float? @map("ch_ward_takedowns_before_20_m")
  challengeJungleCsBefore10Minutes       Float? @map("ch_jungle_cs_before_10_minutes")
  challengeKillAfterHiddenWithAlly       Float? @map("ch_kill_after_hidden_with_ally")
  challengeLandSkillShotsEarlyGame       Float? @map("ch_land_skill_shots_early_game")
  challengePerfectDragonSoulsTaken        Float? @map("ch_perfect_dragon_souls_taken")
  challengeTookLargeDamageSurvived       Float? @map("ch_took_large_damage_survived")
  challengeTwoWardsOneSweeperCount       Float? @map("ch_two_wards_one_sweeper_count")
  challengeMaxLevelLeadLaneOpponent      Float? @map("ch_max_level_lead_lane_opponent")
  challengeTakedownsInEnemyFountain     Float? @map("ch_takedowns_in_enemy_fountain")
  challengeImmobilizeAndKillWithAlly     Float? @map("ch_immobilize_and_kill_with_ally")
  challengeKnockEnemyIntoTeamAndKill     Float? @map("ch_knock_enemy_into_team_and_kill")
  challengeLaneMinionsFirst10Minutes     Float? @map("ch_lane_minions_first_10_minutes")
  challengePlayedChampSelectPosition     Float? @map("ch_played_champ_select_position")
  challengeCompleteSupportQuestInTime    Float? @map("ch_complete_support_quest_in_time")
  challengeDodgeSkillShotsSmallWindow   Float? @map("ch_dodge_skill_shots_small_window")
  challengeMultiTurretRiftHeraldCount    Float? @map("ch_multi_turret_rift_herald_count")
  challengeSurvivedSingleDigitHpCount   Float? @map("ch_survived_single_digit_hp_count")
  challengeTurretsTakenWithRiftHerald   Float? @map("ch_turrets_taken_with_rift_herald")
  challengeLaningPhaseGoldExpAdvantage   Float? @map("ch_laning_phase_gold_exp_advantage")
  challengeMoreEnemyJungleThanOpponent   Float? @map("ch_more_enemy_jungle_than_opponent")
  challengeEnemyChampionImmobilizations Float? @map("ch_enemy_champion_immobilizations")
  challengeKillsWithHelpFromEpicMonster  Float? @map("ch_kills_with_help_from_epic_monster")
  challengeMaxCsAdvantageOnLaneOpponent Float? @map("ch_max_cs_advantage_on_lane_opponent")
  challengeTwentyMinionsIn3SecondsCount Float? @map("ch_twenty_minions_in_3_seconds_count")
  challengeEpicMonsterStolenWithoutSmite Float? @map("ch_epic_monster_stolen_without_smite")
  challengeBlastConeOppositeOpponentCount Float? @map("ch_blast_cone_opposite_opponent_count")
  challengeMultikillsAfterAggressiveFlash Float? @map("ch_multikills_after_aggressive_flash")
  challengeSurvivedThreeImmobilizesInFight Float? @map("ch_survived_three_immobilizes_in_fight")
  challengeEarlyLaningPhaseGoldExpAdvantage Float? @map("ch_early_laning_phase_gold_exp_advantage")
  challengeElderDragonKillsWithOpposingSoul Float? @map("ch_elder_dragon_kills_with_opposing_soul")
  challengeEpicMonsterKillsNearEnemyJungler Float? @map("ch_epic_monster_kills_near_enemy_jungler")
  challengeTakedownsBeforeJungleMinionSpawn Float? @map("ch_takedowns_before_jungle_minion_spawn")
  challengeVisionScoreAdvantageLaneOpponent Float? @map("ch_vision_score_advantage_lane_opponent")
  challengeOuterTurretExecutesBefore10Minutes Float? @map("ch_outer_turret_executes_before_10_minutes")
  challengeBaronBuffGoldAdvantageOverThreshold Float? @map("ch_baron_buff_gold_advantage_over_threshold")
  challengeKillsOnOtherLanesEarlyJungleAsLaner Float? @map("ch_kills_on_other_lanes_early_jungle_as_laner")
  challengeTakedownsAfterGainingLevelAdvantage Float? @map("ch_takedowns_after_gaining_level_advantage")
  challengeKilledChampTookFullTeamDamageSurvived Float? @map("ch_killed_champ_took_full_team_damage_survived")
  challengeEpicMonsterKillsWithin30SecondsOfSpawn Float? @map("ch_epic_monster_kills_within_30_seconds_of_spawn")
  challengeJunglerTakedownsNearDamagedEpicMonster Float? @map("ch_jungler_takedowns_near_damaged_epic_monster")
  challengeGetTakedownsInAllLanesEarlyJungleAsLaner Float? @map("ch_get_takedowns_in_all_lanes_early_jungle_as_laner")
  challengeControlWardTimeCoverageInRiverOrEnemyHalf Float? @map("ch_control_ward_time_coverage_in_river_or_enemy_half")
  createdAt                   DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player @relation(fields: [playerId], references: [id], onDelete: Cascade)

  participantItems             ParticipantItem[]
  participantRunes             ParticipantRune[]
  participantSummonerSpells    ParticipantSummonerSpell[]
  participantSpells            ParticipantSpell[]
  participantPerks             ParticipantPerk[]
  participantJungleFirstClears ParticipantJungleFirstClear[]
  participantSpellOrders       ParticipantSpellOrder[]
  matchTeamFirstObjectives     MatchTeamFirstObjective[]

  @@index([matchId])
  @@index([playerId])
  @@index([championId])
  @@index([rankTier])
  @@index([role])
  @@index([championId, rankTier])
  @@map("participants")
}

// ─── Normalised team data ────────────────────────────────────────────────────

model MatchTeam {
  id                  BigInt   @id @default(autoincrement())
  matchId             BigInt   @map("match_id")
  teamId              Int      @map("team_id") // 100 = blue, 200 = red
  rankTier            String?  @map("rank_tier") // average rank of the 5 participants in this team
  win                 Boolean  @default(false)
  teamEarlySurrendered Boolean @default(false) @map("team_early_surrendered")
  ban1                Int?     @map("ban_1")
  ban2                Int?     @map("ban_2")
  ban3                Int?     @map("ban_3")
  ban4                Int?     @map("ban_4")
  ban5                Int?     @map("ban_5")
  baronKills          Int      @default(0) @map("baron_kills")
  dragonKills         Int      @default(0) @map("dragon_kills")
  towerKills          Int      @default(0) @map("tower_kills")
  hordeKills          Int      @default(0) @map("horde_kills")
  riftHeraldKills     Int      @default(0) @map("rift_herald_kills")
  inhibitorKills      Int      @default(0) @map("inhibitor_kills")
  championKills       Int      @default(0) @map("champion_kills")
  createdAt           DateTime @default(now()) @map("created_at")

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  bans  Ban[]
  drakes MatchTeamDrake[]
  firstObjectiveParticipants MatchTeamFirstObjective[]

  @@unique([matchId, teamId])
  @@index([matchId])
  @@index([teamId])
  @@index([win])
  @@map("match_teams")
}

// Single source of truth for all "first" objectives: which team got it (+ optional killer/assist).
// participant_id set = who got kill (is_kill true) or assist (false); null = team got first, participant unknown (timeline can fill later for herald/horde/dragon/baron).
model MatchTeamFirstObjective {
  id            BigInt   @id @default(autoincrement())
  matchTeamId   BigInt   @map("match_team_id")
  objectiveType String   @map("objective_type") // champion | tower | dragon | baron | horde | rift_herald | inhibitor
  participantId BigInt?  @map("participant_id")  // null = team first only; set = kill or assist
  isKill        Boolean  @default(true) @map("is_kill") // true = kill, false = assist (ignored when participant_id null)

  matchTeam   MatchTeam   @relation(fields: [matchTeamId], references: [id], onDelete: Cascade)
  participant Participant? @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([matchTeamId, objectiveType, participantId])
  @@index([matchTeamId])
  @@index([participantId])
  @@index([objectiveType])
  @@map("match_team_first_objectives")
}

model Ban {
  id          BigInt    @id @default(autoincrement())
  matchTeamId BigInt    @map("match_team_id")
  matchId     BigInt    @map("match_id") // denormalized for simpler queries
  championId  Int       @map("champion_id")
  pickOrder   Int       @map("pick_order") // 1–5
  createdAt   DateTime  @default(now()) @map("created_at")

  matchTeam MatchTeam @relation(fields: [matchTeamId], references: [id], onDelete: Cascade)

  @@index([matchTeamId])
  @@index([matchId])
  @@index([championId])
  @@map("bans")
}

// ─── Normalised participant sub-tables ───────────────────────────────────────

model ParticipantItem {
  id            BigInt   @id @default(autoincrement())
  participantId BigInt   @map("participant_id")
  matchId       BigInt   @map("match_id") // denormalized
  itemId        Int      @map("item_id")
  itemSlot      Int      @map("item_slot") // 0–5 = build slots, 6 = trinket
  starter       Boolean  @default(false)  // first non-ward item purchased (from timeline)

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@index([matchId])
  @@index([itemId])
  @@map("participant_items")
}

model ParticipantRune {
  id            BigInt   @id @default(autoincrement())
  participantId BigInt   @map("participant_id")
  matchId       BigInt   @map("match_id")
  perkId        Int      @map("perk_id")
  slot          Int      // position within style (0-based)
  styleId       Int      @map("style_id")
  var1          Int?     @map("var_1")
  var2          Int?     @map("var_2")
  var3          Int?     @map("var_3")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@index([matchId])
  @@index([perkId])
  @@map("participant_runes")
}

model ParticipantSummonerSpell {
  id            BigInt   @id @default(autoincrement())
  participantId BigInt   @map("participant_id")
  matchId       BigInt   @map("match_id")
  spellId       Int      @map("spell_id")
  spellSlot     Int      @map("spell_slot") // 1 or 2
  casts         Int      @default(0)

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, spellSlot])
  @@index([participantId])
  @@index([matchId])
  @@map("participant_summoner_spells")
}

// Champion spells (Q/W/E/R) cast counts
model ParticipantSpell {
  id            BigInt   @id @default(autoincrement())
  participantId BigInt   @map("participant_id")
  matchId       BigInt   @map("match_id")
  spellSlot     Int      @map("spell_slot") // 1=Q, 2=W, 3=E, 4=R
  casts         Int      @default(0)

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, spellSlot])
  @@index([participantId])
  @@index([matchId])
  @@map("participant_spells")
}

// Stat perks (defense/flex/offense perk IDs)
model ParticipantPerk {
  id            BigInt   @id @default(autoincrement())
  participantId BigInt   @map("participant_id")
  matchId       BigInt   @map("match_id")
  perkId        Int      @map("perk_id")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@index([participantId])
  @@index([matchId])
  @@map("participant_perks")
}

// First clear path order for junglers: one row per camp killed during the first clear.
// Source: timeline participantFrames[].jungleMinionsKilled delta per 1-min frame.
// Only populated for participants with role='JUNGLE'. Capped at JUNGLE_FIRST_CLEAR_MAX_CAMPS camps.
model ParticipantJungleFirstClear {
  id            BigInt   @id @default(autoincrement())
  participantId BigInt   @map("participant_id")
  matchId       BigInt   @map("match_id") // denormalized for simpler queries
  orderIndex    Int      @map("order_index") // 0 = first camp killed, 1 = second, …
  timestampMs   Int      @map("timestamp_ms") // end-of-frame timestamp (ms from game start)

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, orderIndex])
  @@index([matchId, participantId])
  @@index([matchId])
  @@map("participant_jungle_first_clear")
}

// Drake kills per team, in global order across the match (timeline-derived).
// soul is set on the last row for the team when DRAGON_SOUL_GIVEN fires.
model MatchTeamDrake {
  id          BigInt   @id @default(autoincrement())
  matchId     BigInt   @map("match_id")
  matchTeamId BigInt   @map("match_team_id")
  drakeType   String   @map("drake_type") // e.g. "FIRE_DRAGON", "WATER_DRAGON", "ELDER_DRAGON"
  soul        String?  // set when this team received the soul (nullable)
  order       Int      // global kill order across both teams (1 = first drake of the match)

  matchTeam MatchTeam @relation(fields: [matchTeamId], references: [id], onDelete: Cascade)

  @@unique([matchTeamId, order])
  @@index([matchId])
  @@index([matchTeamId])
  @@index([drakeType])
  @@map("match_teams_drake")
}

// Skill level-up order per participant (timeline-derived).
// One row per SKILL_LEVEL_UP event; `order` is 1-based (1 = first skill levelled).
model ParticipantSpellOrder {
  id            BigInt   @id @default(autoincrement())
  participantId BigInt   @map("participant_id")
  matchId       BigInt   @map("match_id") // denormalized
  spellSlot     Int      @map("spell_slot") // 1=Q, 2=W, 3=E, 4=R
  order         Int      // 1-based level-up sequence index for this participant
  timestampMs   Int      @map("timestamp_ms")

  participant Participant @relation(fields: [participantId], references: [id], onDelete: Cascade)

  @@unique([participantId, order])
  @@index([participantId])
  @@index([matchId])
  @@map("participant_spell_orders")
}

// ─── Challenge key discovery registry ────────────────────────────────────────

// Tracks every challenge key seen in Riot data. Keys NOT in the allowlist land here.
// is_new=true until a Discord notification has been sent (transitions to false after notify).
model ChallengeKeyRegistry {
  key          String   @id
  sampleValue  Json     @map("sample_value") // last seen raw value (for Discord notification)
  isNew        Boolean  @default(true) @map("is_new")
  pollValue    Boolean  @default(true) @map("poll_value") // whether to include this key in allowlist candidates
  notifiedAt   DateTime? @map("notified_at")
  firstSeenAt  DateTime  @default(now()) @map("first_seen_at")

  @@map("challenge_keys_registry")
}

// ─── Players ─────────────────────────────────────────────────────────────────

model Player {
  id              BigInt    @id @default(autoincrement())
  gameName        String?   @map("game_name")
  tagName         String?   @map("tag_name")
  puuid           String    @unique
  region          String
  puuidKeyVersion String?   @map("puuid_key_version") // dev|perso|prod — clé Riot utilisée pour ce PUUID
  lastSeen        DateTime? @map("last_seen")
  createdAt       DateTime  @default(now()) @map("created_at")

  participants Participant[]

  @@index([region])
  @@index([puuidKeyVersion])
  @@index([lastSeen])
  @@map("players")
}
