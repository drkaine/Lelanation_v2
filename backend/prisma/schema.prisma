// Lelanation stats: raw match/player data + aggregate stats tables.
// DB: lelanation_stats (same Docker container, DATABASE_URL).
// Migrated from prisma2/ schema; players table preserved from previous schema.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Raw tables ───────────────────────────────────────────────────────────────

model Player {
  id              BigInt    @id @default(autoincrement())
  puuid           String    @unique
  gameName        String?   @map("game_name")
  tagName         String?   @map("tag_name")
  region          String
  puuidKeyVersion String?   @map("puuid_key_version") // dev | persos | prod
  lastSeen        DateTime? @map("last_seen")
  /// Solo-queue snapshot from League v4 (or match DTO) when ingesting the player’s newest stored game.
  rankTier             String?   @map("rank_tier")
  rankDivision         String?   @map("rank_division")
  rankLp               Int?      @map("rank_lp")
  rankSnapshotGameDate DateTime? @map("rank_snapshot_game_date")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  ingestMatchPlayers IngestMatchPlayer[]

  @@index([region])
  @@index([puuidKeyVersion])
  @@index([lastSeen])
  @@index([rankTier])
  @@map("players")
}

// ─── Match ingest (single path; worker fills agg_* / archive_agg_* ) ──

model IngestMatch {
  id                        BigInt    @id @default(autoincrement())
  riotMatchId               String    @unique @map("riot_match_id")
  gameVersion               String    @map("game_version")
  gameDuration              Int       @map("game_duration")
  gameDate                  DateTime? @map("game_date")
  rankTier                  String    @map("rank_tier")
  rankDivision              String    @map("rank_division")
  gameEndedInSurrender      Boolean   @default(false) @map("game_ended_in_surrender")
  gameEndedInEarlySurrender Boolean   @default(false) @map("game_ended_in_early_surrender")
  region                    String

  teams        IngestTeam[]
  matchPlayers IngestMatchPlayer[]

  @@index([gameVersion])
  @@index([rankTier])
  @@index([region])
  @@index([gameVersion, region, rankTier])
  @@index([gameDate])
  @@map("ingest_matchs")
}

model IngestTeam {
  id                   BigInt @id @default(autoincrement())
  matchId              BigInt @map("match_id")
  team                 Int
  rankTier             String @default("UNRANKED") @map("rank_tier")
  win                  Boolean
  teamEarlySurrendered Boolean @default(false) @map("team_early_surrendered")
  baronKills           Int    @default(0) @map("baron_kills")
  baronFirst           Boolean @default(false) @map("baron_first")
  dragonKills          Int    @default(0) @map("dragon_kills")
  dragonFirst          Boolean @default(false) @map("dragon_first")
  towerKills           Int    @default(0) @map("tower_kills")
  towerFirst           Boolean @default(false) @map("tower_first")
  hordeKills           Int    @default(0) @map("horde_kills")
  hordeFirst           Boolean @default(false) @map("horde_first")
  riftHeraldKills      Int    @default(0) @map("rift_herald_kills")
  riftHeraldFirst      Boolean @default(false) @map("rift_herald_first")
  inhibitorKills       Int    @default(0) @map("inhibitor_kills")
  inhibitorFirst       Boolean @default(false) @map("inhibitor_first")
  championKills        Int    @default(0) @map("champion_kills")
  firstBlood           Boolean @default(false) @map("first_blood")
  elderKills           Int    @default(0) @map("elder_kills")
  /// Bans from match-v5 team payload: [{ championId, pickOrder }, ...].
  bansJson   Json @default("[]") @map("bans_json")
  /// Drake timeline sequence: [{ drakeType, order, soul }, ...].
  drakesJson Json @default("[]") @map("drakes_json")

  match        IngestMatch         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchPlayers IngestMatchPlayer[]

  @@unique([matchId, team])
  @@index([matchId])
  @@map("ingest_teams")
}

model IngestMatchPlayer {
  id             BigInt  @id @default(autoincrement())
  matchId        BigInt  @map("match_id")
  playerId       BigInt  @map("player_id")
  teamId         BigInt  @map("team_id")
  championId     Int     @map("champion_id")
  role           String
  rankTier       String  @default("UNRANKED") @map("rank_tier")
  rankDivision   String? @map("rank_division")
  participantId  Int     @map("participant_id")
  items          Json    @default("[]")
  runes          Int[]   @default([])
  shards         Int[]   @default([])
  summonerSpells Int[]   @default([]) @map("summoner_spells")
  skillOrder     Json?   @map("skill_order")
  win            Boolean @default(false)
  kills          Int     @default(0)
  deaths         Int     @default(0)
  assists        Int     @default(0)
  /// Participant-derived payload (damage, vision, challenges, timeline buckets, etc.).
  stats Json @default("{}")

  match  IngestMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team   IngestTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
  @@index([championId])
  @@index([championId, role, rankTier])
  @@map("ingest_match_players")
}

/// One row per (UTC day summarized, rank tier without division, champion). Filled daily by poller job.
model ChampionTierDailySnapshot {
  id              BigInt   @id @default(autoincrement())
  dateOfGame      DateTime @db.Date @map("date_of_game")
  rankTier        String   @map("rank_tier")
  role            String   @map("role")
  championId      Int      @map("champion_id")
  games           Int      @default(0)
  wins            Int      @default(0)
  banRatePct      Float    @default(0) @map("ban_rate_pct")
  pickRatePct     Float    @map("pick_rate_pct")

  @@unique([dateOfGame, rankTier, role, championId])
  @@index([championId, dateOfGame(sort: Desc)])
  @@index([rankTier, role, dateOfGame(sort: Desc)])
  @@map("champion_tier_daily_snapshots")
}

model ActivePatch {
  gameVersion String   @map("game_version")
  activatedAt DateTime @default(now()) @map("activated_at")
  isCurrent   Boolean  @default(true) @map("is_current")
  gamesNumber Int      @default(0) @map("games_number")
  gameNumberMax Int    @default(1000000) @map("game_number_max")
  /// Set when close_patch() moved agg rows to archive_agg_* ; frozen games_number for UI.
  archivedAt  DateTime? @map("archived_at")

  @@id([gameVersion])
  @@map("active_patches")
}

model MatchIngestRaw {
  id                BigInt    @id @default(autoincrement())
  riotMatchId       String    @map("riot_match_id")
  region            String
  payloadJson       Json      @map("payload_json")
  timelineJson      Json?     @map("timeline_json")
  status            String    @default("pending")
  attemptCount      Int       @default(0) @map("attempt_count")
  lastError         String?   @map("last_error")
  ingestedAt        DateTime  @default(now()) @map("ingested_at")
  normalizedAt      DateTime? @map("normalized_at")
  processingStartedAt DateTime? @map("processing_started_at")
  nextRetryAt       DateTime? @map("next_retry_at")

  @@index([status, id], map: "idx_match_ingest_raw_status_id")
  @@index([riotMatchId], map: "idx_match_ingest_raw_riot_match_id")
  @@index([status, nextRetryAt, id], map: "idx_match_ingest_raw_next_retry")
  @@map("match_ingest_raw")
}

model TrackedMatch {
  matchId              String   @id @map("match_id")
  status               String   @default("PENDING")
  createdAt            DateTime @default(now()) @map("created_at")
  aggregateStatus      String   @default("PENDING") @map("aggregate_status")
  aggregateAttemptCount Int      @default(0) @map("aggregate_attempt_count")
  aggregateLastError   String?  @map("aggregate_last_error")
  aggregatedAt         DateTime? @map("aggregated_at")
  player1              Json?    @map("player1")
  player2              Json?    @map("player2")
  player3              Json?    @map("player3")
  player4              Json?    @map("player4")
  player5              Json?    @map("player5")
  player6              Json?    @map("player6")
  player7              Json?    @map("player7")
  player8              Json?    @map("player8")
  player9              Json?    @map("player9")
  player10             Json?    @map("player10")

  @@index([aggregateStatus], map: "idx_tracked_matches_aggregate_status")
  @@index([aggregatedAt], map: "idx_tracked_matches_aggregated_at")
  @@map("tracked_matches")
}

/// Incremental champion aggregates (live `agg_champion_core_stats` + `archive_agg_champion_core_stats` after close_patch).
/// Materialized views `mv_*` were dropped; API reads via `matchVersionedAggFrom` / raw SQL.
model AggChampionCoreStat {
  id                             BigInt   @id
  championId                     Int      @map("champion_id")
  role                           String
  rankTier                       String   @map("rank_tier")
  gameVersion                    String   @map("game_version")
  region                         String
  countWin                       Int      @default(0) @map("count_win")
  countGame                      Int      @default(0) @map("count_game")
  countBan                       Int      @default(0) @map("count_ban")
  sumGoldEarned                  BigInt   @default(0) @map("sum_gold_earned")
  sumGoldSpent                   BigInt   @default(0) @map("sum_gold_spent")
  sumMaxLevelLeadLaneOpponent    Int      @default(0) @map("sum_max_level_lead_lane_opponent")
  sumMaxKillDeficit              Int      @default(0) @map("sum_max_kill_deficit")
  sumMoreEnemyJungleThanOpponent Int      @default(0) @map("sum_more_enemy_jungle_than_opponent")
  sumMaxCsAdvantageOnLaneOpponent Int     @default(0) @map("sum_max_cs_advantage_on_lane_opponent")
  sumVisionScoreAdvantageLaneOpponent Int @default(0) @map("sum_vision_score_advantage_lane_opponent")
  sumLaningPhaseGoldExpAdvantage Int      @default(0) @map("sum_laning_phase_gold_exp_advantage")
  sumEarlyLaningPhaseGoldExpAdvantage Int @default(0) @map("sum_early_laning_phase_gold_exp_advantage")
  updatedAt                      DateTime @default(now()) @map("updated_at") @db.Timestamptz(6)

  @@unique([championId, role, rankTier, gameVersion, region], map: "idx_agg_champion_core_dims")
  @@map("agg_champion_core_stats")
}

