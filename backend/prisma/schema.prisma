  damageDealtToEpicMonsters     Int    @default(0) @map("damage_dealt_to_epic_monsters")
  damageDealtToObjectives       Int    @default(0) @map("damage_dealt_to_objectives")
  damageDealtToTurrets          Int    @default(0) @map("damage_dealt_to_turrets")
  damageSelfMitigated           Int    @default(0) @map("damage_self_mitigated")
  doubleKills                   Int    @default(0) @map("double_kills")
  killingSprees                 Int    @default(0) @map("killing_sprees")
  largestCriticalStrike         Int    @default(0) @map("largest_critical_strike")
  largestKillingSpree           Int    @default(0) @map("largest_killing_spree")
  longestTimeSpentLiving        Int    @default(0) @map("longest_time_spent_living")
  magicDamageDealt              Int    @default(0) @map("magic_damage_dealt")
  magicDamageDealtToChampions   Int    @default(0) @map("magic_damage_dealt_to_champions")
  magicDamageTaken              Int    @default(0) @map("magic_damage_taken")
  pentaKills                    Int    @default(0) @map("penta_kills")
  physicalDamageDealt           Int    @default(0) @map("physical_damage_dealt")
  physicalDamageDealtToChampions Int   @default(0) @map("physical_damage_dealt_to_champions")
  physicalDamageTaken           Int    @default(0) @map("physical_damage_taken")
  quadraKills                   Int    @default(0) @map("quadra_kills")
  totalDamageShieldedOnTeammates Int   @default(0) @map("total_damage_shielded_on_teammates")
  totalDamageTaken              Int    @default(0) @map("total_damage_taken")
  totalHeal                     Int    @default(0) @map("total_heal")
  totalHealsOnTeammates         Int    @default(0) @map("total_heals_on_teammates")
  totalTimeCcDealt              Int    @default(0) @map("total_time_cc_dealt")
  totalUnitsHealed              Int    @default(0) @map("total_units_healed")
  tripleKills                   Int    @default(0) @map("triple_kills")
  trueDamageDealt               Int    @default(0) @map("true_damage_dealt")
  trueDamageDealtToChampions    Int    @default(0) @map("true_damage_dealt_to_champions")
  trueDamageTaken               Int    @default(0) @map("true_damage_taken")
  effectiveHealAndShielding     Int    @default(0) @map("effective_heal_and_shielding")
  timeCcingOthers               Int    @default(0) @map("time_ccing_others")
  enemyChampionImmobilizations  Int    @default(0) @map("enemy_champion_immobilizations")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_combats")
}

model MatchPlayerChallenges {
  matchPlayerId                             BigInt @id @map("match_player_id")
  healFromMapSources                        Int    @default(0) @map("heal_from_map_sources")
  buffsStolen                               Int    @default(0) @map("buffs_stolen")
  dodgeSkillShotsSmallWindow                Int    @default(0) @map("dodge_skill_shots_small_window")
  hadOpenNexus                              Int    @default(0) @map("had_open_nexus")
  immobilizeAndKillWithAlly                 Int    @default(0) @map("immobilize_and_kill_with_ally")
  junglerTakedownsNearDamagedEpicMonster    Int    @default(0) @map("jungler_takedowns_near_damaged_epic_monster")
  killAfterHiddenWithAlly                   Int    @default(0) @map("kill_after_hidden_with_ally")
  killedChampTookFullTeamDamageSurvived     Int    @default(0) @map("killed_champ_took_full_team_damage_survived")
  killsWithHelpFromEpicMonster              Int    @default(0) @map("kills_with_help_from_epic_monster")
  knockEnemyIntoTeamAndKill                 Int    @default(0) @map("knock_enemy_into_team_and_kill")
  mejaisFullStackInTime                     Int    @default(0) @map("mejais_full_stack_in_time")
  multikillsAfterAggressiveFlash            Int    @default(0) @map("multikills_after_aggressive_flash")
  quickCleanse                              Int    @default(0) @map("quick_cleanse")
  saveAllyFromDeath                         Int    @default(0) @map("save_ally_from_death")
  scuttleCrabKills                          Int    @default(0) @map("scuttle_crab_kills")
  skillshotsDodged                          Int    @default(0) @map("skillshots_dodged")
  skillshotsHit                             Int    @default(0) @map("skillshots_hit")
  stealthWardsPlaced                        Int    @default(0) @map("stealth_wards_placed")
  survivedSingleDigitHpCount                Int    @default(0) @map("survived_single_digit_hp_count")
  survivedThreeImmobilizesInFight           Int    @default(0) @map("survived_three_immobilizes_in_fight")
  takedownsBeforeJungleMinionSpawn          Int    @default(0) @map("takedowns_before_jungle_minion_spawn")
  takedownsInAlcove                         Int    @default(0) @map("takedowns_in_alcove")
  takedownsInEnemyFountain                  Int    @default(0) @map("takedowns_in_enemy_fountain")
  tookLargeDamageSurvived                   Int    @default(0) @map("took_large_damage_survived")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_challenges")
}

model MatchPlayerItem {
  id            BigInt  @id @default(autoincrement())
  matchPlayerId BigInt  @map("match_player_id")
  itemId        Int     @map("item_id")
  starter       Boolean @default(false)
  core          Boolean @default(false)
  order         Int     @map("order")
  timestampMs   Int     @default(0) @map("timestamp_ms")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@unique([matchPlayerId, itemId, order])
  @@index([matchPlayerId])
  @@index([itemId])
  @@map("match_player_items")
}

model MatchPlayerRune {
  id            BigInt @id @default(autoincrement())
  matchPlayerId BigInt @map("match_player_id")
  perkId        Int    @map("perk_id")
  style         Int

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@index([matchPlayerId])
  @@map("match_player_runes")
}

model MatchPlayerSummonerSpell {
  id            BigInt @id @default(autoincrement())
  matchPlayerId BigInt @map("match_player_id")
  spellId       Int    @map("spell_id")
  spellSlot     Int    @map("spell_slot") // 0 | 1

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@unique([matchPlayerId, spellSlot])
  @@index([matchPlayerId])
  @@map("match_player_summoner_spells")
}

model MatchPlayerShard {
  id            BigInt @id @default(autoincrement())
  matchPlayerId BigInt @map("match_player_id")
  shardId       Int    @map("shard_id")
  slot          Int    // 0 | 1 | 2

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@unique([matchPlayerId, slot])
  @@index([matchPlayerId])
  @@map("match_player_shards")
}

model MatchPlayerSpellOrder {
  id            BigInt @id @default(autoincrement())
  matchPlayerId BigInt @map("match_player_id")
  spellSlot     Int    @map("spell_slot") // 1-4
  order         Int    @map("order")
  timestampMs   Int    @default(0) @map("timestamp_ms")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@index([matchPlayerId])
  @@map("match_player_spell_orders")
}

model MatchPlayerBucket {
  id                           BigInt @id @default(autoincrement())
  matchPlayerId                BigInt @map("match_player_id")
  durationBucket               Int    @map("duration_bucket")
  currentGold                  Int    @default(0) @map("current_gold")
  magicDamageDone              Int    @default(0) @map("magic_damage_done")
  magicDamageDoneToChampion    Int    @default(0) @map("magic_damage_done_to_champion")
  magicDamageTaken             Int    @default(0) @map("magic_damage_taken")
  physicalDamageDone           Int    @default(0) @map("physical_damage_done")
  physicalDamageDoneToChampion Int    @default(0) @map("physical_damage_done_to_champion")
  physicalDamageTaken          Int    @default(0) @map("physical_damage_taken")
  totalDamageDone              Int    @default(0) @map("total_damage_done")
  totalDamageDoneToChampion    Int    @default(0) @map("total_damage_done_to_champion")
  totalDamageTaken             Int    @default(0) @map("total_damage_taken")
  trueDamageDone               Int    @default(0) @map("true_damage_done")
  trueDamageDoneToChampion     Int    @default(0) @map("true_damage_done_to_champion")
  trueDamageTaken              Int    @default(0) @map("true_damage_taken")
  goldPerSecond                Int    @default(0) @map("gold_per_second")
  jungleMinionsKilled          Int    @default(0) @map("jungle_minions_killed")
  level                        Int    @default(0) @map("level")
  minionsKilled                Int    @default(0) @map("minions_killed")
  timeEnemySpentControlled     Int    @default(0) @map("time_enemy_spent_controlled")
  totalGold                    Int    @default(0) @map("total_gold")
  xp                           Int    @default(0) @map("xp")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@unique([matchPlayerId, durationBucket])
  @@index([matchPlayerId])
  @@map("match_player_bucket")
}

// ─── Aggregate tables (filled by stats aggregation jobs) ─────────────────────

model ChampionCoreStat {
  id                             BigInt  @id @default(autoincrement())
  championId                     Int     @map("champion_id")
  rankTier                       String  @map("rank_tier")
  rankDivision                   String  @default("") @map("rank_division")
  gameVersion                    String  @map("game_version")
  role                           String  // TOP, JUNGLE, MID, ADC, SUPPORT
  region                         String
  countWin                       Int     @default(0) @map("count_win")
  countGame                      Int     @default(0) @map("count_game")
  sumGameDuration                BigInt  @default(0) @map("sum_game_duration")
  countTeam100                   Int     @default(0) @map("count_team_100")
  countTeam200                   Int     @default(0) @map("count_team_200")
  countGameEndedInSurrender      Int     @default(0) @map("count_game_ended_in_surrender")
  countGameEndedInEarlySurrender Int     @default(0) @map("count_game_ended_in_early_surrender")
  countTeamEarlySurrendered      Int     @default(0) @map("count_team_early_surrendered")
  countBan                       Int     @default(0) @map("count_ban")
  sumKills                       BigInt  @default(0) @map("sum_kills")
  sumDeaths                      BigInt  @default(0) @map("sum_deaths")
  sumAssists                     BigInt  @default(0) @map("sum_assists")
  sumChampLevel                  BigInt  @default(0) @map("sum_champ_level")
  sumChampExperience             BigInt  @default(0) @map("sum_champ_experience")
  sumGoldEarned                  BigInt  @default(0) @map("sum_gold_earned")
  sumGoldSpent                   BigInt  @default(0) @map("sum_gold_spent")
  sumTotalMinionsKilled          BigInt  @default(0) @map("sum_total_minions_killed")
  sumConsumablesPurchased        BigInt  @default(0) @map("sum_consumables_purchased")
