// Lelanation stats: raw match/player data + aggregate stats tables.
// DB: lelanation_stats (same Docker container, DATABASE_URL).
// Migrated from prisma2/ schema; players table preserved from previous schema.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Raw tables ───────────────────────────────────────────────────────────────

model Player {
  id              BigInt    @id @default(autoincrement())
  puuid           String    @unique
  gameName        String?   @map("game_name")
  tagName         String?   @map("tag_name")
  region          String
  puuidKeyVersion String?   @map("puuid_key_version") // dev | persos | prod
  lastSeen        DateTime? @map("last_seen")
  createdAt       DateTime  @default(now()) @map("created_at")

  matchPlayers MatchPlayer[]

  @@index([region])
  @@index([puuidKeyVersion])
  @@index([lastSeen])
  @@map("players")
}

model Match {
  id                        BigInt    @id @default(autoincrement())
  riotMatchId               String    @unique @map("riot_match_id")
  gameVersion               String    @map("game_version")
  gameDuration              Int       @map("game_duration")
  rankTier                  String    @map("rank_tier")
  rankDivision              String    @map("rank_division")
  gameEndedInSurrender      Boolean   @default(false) @map("game_ended_in_surrender")
  gameEndedInEarlySurrender Boolean   @default(false) @map("game_ended_in_early_surrender")
  region                    String
  aggregatedAt              DateTime? @map("aggregated_at")

  teams        Team[]
  drakeDetails DrakeDetail[]
  matchPlayers MatchPlayer[]

  @@index([gameVersion])
  @@index([rankTier])
  @@index([region])
  @@index([gameVersion, region, rankTier])
  @@index([aggregatedAt])
  @@map("matchs")
}

model Team {
  id                   BigInt   @id @default(autoincrement())
  matchId              BigInt   @map("match_id")
  team                 Int      // 100 | 200
  win                  Boolean
  teamEarlySurrendered Boolean  @default(false) @map("team_early_surrendered")
  baronKills           Int      @default(0) @map("baron_kills")
  baronFirst           Boolean  @default(false) @map("baron_first")
  dragonKills          Int      @default(0) @map("dragon_kills")
  dragonFirst          Boolean  @default(false) @map("dragon_first")
  towerKills           Int      @default(0) @map("tower_kills")
  towerFirst           Boolean  @default(false) @map("tower_first")
  hordeKills           Int      @default(0) @map("horde_kills")
  hordeFirst           Boolean  @default(false) @map("horde_first")
  riftHeraldKills      Int      @default(0) @map("rift_herald_kills")
  riftHeraldFirst      Boolean  @default(false) @map("rift_herald_first")
  inhibitorKills       Int      @default(0) @map("inhibitor_kills")
  championKills        Int      @default(0) @map("champion_kills")
  firstBlood           Boolean  @default(false) @map("first_blood")
  elderKills           Int      @default(0) @map("elder_kills")

  match        Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  bans         Ban[]
  drakeDetails DrakeDetail[]
  matchPlayers MatchPlayer[]

  @@unique([matchId, team])
  @@index([matchId])
  @@map("teams")
}

model Ban {
  id         BigInt @id @default(autoincrement())
  teamId     BigInt @map("team_id")
  matchId    BigInt @map("match_id")
  championId Int    @map("champion_id")
  pickOrder  Int    @map("pick_order") // 1-5

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([matchId])
  @@index([championId])
  @@map("bans")
}

model DrakeDetail {
  id        BigInt @id @default(autoincrement())
  matchId   BigInt @map("match_id")
  teamId    BigInt @map("team_id")
  drakeType String @map("drake_type") // earth, water, wind, fire, hextech, chemtech, elder
  order     Int    @map("order")
  soul      String

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([teamId])
  @@map("drake_details")
}

model MatchPlayer {
  id            BigInt  @id @default(autoincrement())
  matchId       BigInt  @map("match_id")
  playerId      BigInt  @map("player_id")
  teamId        BigInt  @map("team_id")
  championId    Int     @map("champion_id")
  role          String  // TOP, JUNGLE, MID, ADC, SUPPORT
  rankTier      String  @default("UNRANKED") @map("rank_tier")
  rankDivision  String? @map("rank_division")
  rankLp        Int?    @map("rank_lp")
  participantId Int     @map("participant_id")

  match          Match                    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player         Player                   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team           Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  core           MatchPlayerCore?
  visions        MatchPlayerVisions?
  matchup        MatchPlayerMatchup?
  objectives     MatchPlayerObjectives?
  combats        MatchPlayerCombats?
  challenges     MatchPlayerChallenges?
  items          MatchPlayerItem[]
  runes          MatchPlayerRune[]
  summonerSpells MatchPlayerSummonerSpell[]
  shards         MatchPlayerShard[]
  spellOrders    MatchPlayerSpellOrder[]
  buckets        MatchPlayerBucket[]

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
  @@index([championId])
  @@index([championId, role, rankTier])
  @@map("match_players")
}

model MatchPlayerCore {
  matchPlayerId        BigInt @id @map("match_player_id")
  kills                Int    @default(0)
  deaths               Int    @default(0)
  assists              Int    @default(0)
  champLevel           Int    @default(0) @map("champ_level")
  champExperience      Int    @default(0) @map("champ_experience")
  goldEarned           Int    @default(0) @map("gold_earned")
  goldSpent            Int    @default(0) @map("gold_spent")
  itemsPurchased       Int    @default(0) @map("items_purchased")
  consumablesPurchased Int    @default(0) @map("consumables_purchased")
  totalMinionsKilled   Int    @default(0) @map("total_minions_killed")
  roleBoundItem        Int    @default(0) @map("role_bound_item")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_core")
}

model MatchPlayerVisions {
  matchPlayerId                   BigInt @id @map("match_player_id")
  detectorWardsPlaced             Int    @default(0) @map("detector_wards_placed")
  visionScore                     Int    @default(0) @map("vision_score")
  visionWardsBoughtInGame         Int    @default(0) @map("vision_wards_bought_in_game")
  wardsKilled                     Int    @default(0) @map("wards_killed")
  wardsPlaced                     Int    @default(0) @map("wards_placed")
  controlWardsPlaced              Int    @default(0) @map("control_wards_placed")
  unseenRecalls                   Int    @default(0) @map("unseen_recalls")
  visionScoreAdvantageLaneOpponent Int   @default(0) @map("vision_score_advantage_lane_opponent")
  wardTakedowns                   Int    @default(0) @map("ward_takedowns")
  wardTakedownsBefore20M          Int    @default(0) @map("ward_takedowns_before_20_m")
  wardsGuarded                    Int    @default(0) @map("wards_guarded")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_visions")
}

model MatchPlayerMatchup {
  matchPlayerId                       BigInt @id @map("match_player_id")
  bountyGold                          Int    @default(0) @map("bounty_gold")
  completeSupportQuestInTime          Int    @default(0) @map("complete_support_quest_in_time")
  deathsByEnemyChamps                 Int    @default(0) @map("deaths_by_enemy_champs")
  earlyLaningPhaseGoldExpAdvantage    Int    @default(0) @map("early_laning_phase_gold_exp_advantage")
  initialCrabCount                    Int    @default(0) @map("initial_crab_count")
  jungleCsBefore10Minutes             Int    @default(0) @map("jungle_cs_before_10_minutes")
  killsNearEnemyTurret                Int    @default(0) @map("kills_near_enemy_turret")
  killsOnOtherLanesEarlyJungleAsLaner Int    @default(0) @map("kills_on_other_lanes_early_jungle_as_laner")
  killsUnderOwnTurret                 Int    @default(0) @map("kills_under_own_turret")
  landSkillShotsEarlyGame             Int    @default(0) @map("land_skill_shots_early_game")
  laneMinionsFirst10Minutes           Int    @default(0) @map("lane_minions_first_10_minutes")
  laningPhaseGoldExpAdvantage         Int    @default(0) @map("laning_phase_gold_exp_advantage")
  maxCsAdvantageOnLaneOpponent        Int    @default(0) @map("max_cs_advantage_on_lane_opponent")
  maxKillDeficit                      Int    @default(0) @map("max_kill_deficit")
  maxLevelLeadLaneOpponent            Int    @default(0) @map("max_level_lead_lane_opponent")
  outnumberedKills                    Int    @default(0) @map("outnumbered_kills")
  quickSoloKills                      Int    @default(0) @map("quick_solo_kills")
  soloKills                           Int    @default(0) @map("solo_kills")
  takedownsAfterGainingLevelAdvantage Int    @default(0) @map("takedowns_after_gaining_level_advantage")
  moreEnemyJungleThanOpponent         Int    @default(0) @map("more_enemy_jungle_than_opponent")
  totalAllyJungleMinionsKilled        Int    @default(0) @map("total_ally_jungle_minions_killed")
  totalEnemyJungleMinionsKilled       Int    @default(0) @map("total_enemy_jungle_minions_killed")
  neutralMinionsKilled                Int    @default(0) @map("neutral_minions_killed")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_matchup")
}

model MatchPlayerObjectives {
