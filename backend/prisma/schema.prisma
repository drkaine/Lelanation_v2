  sumPhysicalDamageDoneToChampion Int @default(0) @map("sum_physical_damage_done_to_champion")
  sumPhysicalDamageTaken       Int    @default(0) @map("sum_physical_damage_taken")
  sumTotalDamageDone           Int    @default(0) @map("sum_total_damage_done")
  sumTotalDamageDoneToChampion Int    @default(0) @map("sum_total_damage_done_to_champion")
  sumTotalDamageTaken          Int    @default(0) @map("sum_total_damage_taken")
  sumTrueDamageDone            Int    @default(0) @map("sum_true_damage_done")
  sumTrueDamageDoneToChampion  Int    @default(0) @map("sum_true_damage_done_to_champion")
  sumTrueDamageTaken           Int    @default(0) @map("sum_true_damage_taken")
  sumGoldPerSecond             Int    @default(0) @map("sum_gold_per_second")
  sumJungleMinionsKilled       Int    @default(0) @map("sum_jungle_minions_killed")
  sumLevel                     Int    @default(0) @map("sum_level")
  sumMinionsKilled             Int    @default(0) @map("sum_minions_killed")
  sumTimeEnemySpentControlled  Int    @default(0) @map("sum_time_enemy_spent_controlled")
  sumTotalGold                 Int    @default(0) @map("sum_total_gold")
  sumXp                        Int    @default(0) @map("sum_xp")

  championCoreStat ChampionCoreStat @relation(fields: [championStatId], references: [id], onDelete: Cascade)

  @@id([championStatId, durationBucket])
  @@index([championStatId])
  @@map("champion_bucket")
}
