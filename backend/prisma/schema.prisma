  dragonKills                            Int     @default(0) @map("dragon_kills")
  firstBloodKill                         Boolean @default(false) @map("first_blood_kill")
  firstBloodAssist                       Boolean @default(false) @map("first_blood_assist")
  firstTowerKill                         Boolean @default(false) @map("first_tower_kill")
