model MvChampionBucket {
  championStatId               BigInt @map("champion_stat_id")
  durationBucket               Int    @map("duration_bucket")
  countWin                     Int    @map("count_win")
  countGame                    Int    @map("count_game")
  sumCurrentGold               Int    @map("sum_current_gold")
  sumMagicDamageDone           Int    @map("sum_magic_damage_done")
  sumMagicDamageDoneToChampion Int    @map("sum_magic_damage_done_to_champion")
  sumMagicDamageTaken          Int    @map("sum_magic_damage_taken")
  sumPhysicalDamageDone        Int    @map("sum_physical_damage_done")
  sumPhysicalDamageDoneToChampion Int @map("sum_physical_damage_done_to_champion")
  sumPhysicalDamageTaken       Int    @map("sum_physical_damage_taken")
  sumTotalDamageDone           Int    @map("sum_total_damage_done")
  sumTotalDamageDoneToChampion Int    @map("sum_total_damage_done_to_champion")
  sumTotalDamageTaken          Int    @map("sum_total_damage_taken")
  sumTrueDamageDone            Int    @map("sum_true_damage_done")
  sumTrueDamageDoneToChampion  Int    @map("sum_true_damage_done_to_champion")
  sumTrueDamageTaken           Int    @map("sum_true_damage_taken")
  sumGoldPerSecond             Int    @map("sum_gold_per_second")
  sumJungleMinionsKilled       Int    @map("sum_jungle_minions_killed")
  sumLevel                     Int    @map("sum_level")
  sumMinionsKilled             Int    @map("sum_minions_killed")
  sumTimeEnemySpentControlled  Int    @map("sum_time_enemy_spent_controlled")
  sumTotalGold                 Int    @map("sum_total_gold")
  sumXp                        Int    @map("sum_xp")
  countGameFinishedAtBucket    Int    @map("count_game_finished_at_bucket")

  @@id([championStatId, durationBucket])
  @@map("mv_champion_bucket")
}

model MvTeamBucket {
  teamStatId      BigInt @map("team_stat_id")
  objectiveKey    String @map("objective_key")
  objectiveBucket Int    @map("objective_bucket")
  countWin        Int    @map("count_win")
  countGame       Int    @map("count_game")

  @@id([teamStatId, objectiveKey, objectiveBucket])
  @@map("mv_team_bucket")
}
