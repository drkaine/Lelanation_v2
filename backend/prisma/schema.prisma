// Lelanation stats: raw match/player data + aggregate stats tables.
// DB: lelanation_stats (same Docker container, DATABASE_URL).
// Migrated from prisma2/ schema; players table preserved from previous schema.

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Raw tables ───────────────────────────────────────────────────────────────

model Player {
  id              BigInt    @id @default(autoincrement())
  puuid           String    @unique
  gameName        String?   @map("game_name")
  tagName         String?   @map("tag_name")
  region          String
  puuidKeyVersion String?   @map("puuid_key_version") // dev | persos | prod
  lastSeen        DateTime? @map("last_seen")
  /// Solo-queue snapshot from League v4 (or match DTO) when ingesting the player’s newest stored game.
  rankTier             String?   @map("rank_tier")
  rankDivision         String?   @map("rank_division")
  rankLp               Int?      @map("rank_lp")
  rankSnapshotGameDate DateTime? @map("rank_snapshot_game_date")
  createdAt       DateTime  @default(now()) @map("created_at")

  matchPlayers       MatchPlayer[]
  ingestMatchPlayers IngestMatchPlayer[]

  @@index([region])
  @@index([puuidKeyVersion])
  @@index([lastSeen])
  @@index([rankTier])
  @@map("players")
}

model Match {
  id                        BigInt    @id @default(autoincrement())
  riotMatchId               String    @unique @map("riot_match_id")
  gameVersion               String    @map("game_version")
  gameDuration              Int       @map("game_duration")
  gameDate                  DateTime? @map("game_date")
  rankTier                  String    @map("rank_tier")
  rankDivision              String    @map("rank_division")
  gameEndedInSurrender      Boolean   @default(false) @map("game_ended_in_surrender")
  gameEndedInEarlySurrender Boolean   @default(false) @map("game_ended_in_early_surrender")
  region                    String

  teams        Team[]
  drakeDetails DrakeDetail[]
  matchPlayers MatchPlayer[]

  @@index([gameVersion])
  @@index([rankTier])
  @@index([region])
  @@index([gameVersion, region, rankTier])
  @@index([gameDate])
  @@map("matchs")
}

model Team {
  id                   BigInt   @id @default(autoincrement())
  matchId              BigInt   @map("match_id")
  team                 Int      // 100 | 200
  rankTier             String   @default("UNRANKED") @map("rank_tier")
  win                  Boolean
  teamEarlySurrendered Boolean  @default(false) @map("team_early_surrendered")
  baronKills           Int      @default(0) @map("baron_kills")
  baronFirst           Boolean  @default(false) @map("baron_first")
  dragonKills          Int      @default(0) @map("dragon_kills")
  dragonFirst          Boolean  @default(false) @map("dragon_first")
  towerKills           Int      @default(0) @map("tower_kills")
  towerFirst           Boolean  @default(false) @map("tower_first")
  hordeKills           Int      @default(0) @map("horde_kills")
  hordeFirst           Boolean  @default(false) @map("horde_first")
  riftHeraldKills      Int      @default(0) @map("rift_herald_kills")
  riftHeraldFirst      Boolean  @default(false) @map("rift_herald_first")
  inhibitorKills       Int      @default(0) @map("inhibitor_kills")
  championKills        Int      @default(0) @map("champion_kills")
  firstBlood           Boolean  @default(false) @map("first_blood")
  elderKills           Int      @default(0) @map("elder_kills")

  match        Match         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  bans         Ban[]
  drakeDetails DrakeDetail[]
  matchPlayers MatchPlayer[]

  @@unique([matchId, team])
  @@index([matchId])
  @@map("teams")
}

model Ban {
  id         BigInt @id @default(autoincrement())
  teamId     BigInt @map("team_id")
  matchId    BigInt @map("match_id")
  championId Int    @map("champion_id")
  pickOrder  Int    @map("pick_order") // 1-5

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([teamId])
  @@index([matchId])
  @@index([championId])
  @@map("bans")
}

model DrakeDetail {
  id        BigInt @id @default(autoincrement())
  matchId   BigInt @map("match_id")
  teamId    BigInt @map("team_id")
  drakeType String @map("drake_type") // earth, water, wind, fire, hextech, chemtech, elder
  order     Int    @map("order")
  soul      String

  match Match @relation(fields: [matchId], references: [id], onDelete: Cascade)
  team  Team  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@index([matchId])
  @@index([teamId])
  @@map("drake_details")
}

model MatchPlayer {
  id            BigInt  @id @default(autoincrement())
  matchId       BigInt  @map("match_id")
  playerId      BigInt  @map("player_id")
  teamId        BigInt  @map("team_id")
  championId    Int     @map("champion_id")
  role          String  // TOP, JUNGLE, MID, ADC, SUPPORT
  rankTier      String  @default("UNRANKED") @map("rank_tier")
  rankDivision  String? @map("rank_division")
  participantId Int     @map("participant_id")
  items         Json    @default("[]")
  runes         Int[]   @default([])
  shards        Int[]   @default([])
  /// Summoner spell IDs in slot order (D then F): [summoner1Id, summoner2Id].
  summonerSpells Int[]  @default([]) @map("summoner_spells")
  /// Skill level-up sequence from timeline: [1,2,3,...] where 1=Q,2=W,3=E,4=R.
  skillOrder    Json?   @map("skill_order")

  match          Match                    @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player         Player                   @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team           Team                     @relation(fields: [teamId], references: [id], onDelete: Cascade)
  core           MatchPlayerCore?
  visions        MatchPlayerVisions?
  matchup        MatchPlayerMatchup?
  objectives     MatchPlayerObjectives?
  combats        MatchPlayerCombats?
  challenges     MatchPlayerChallenges?
  buckets        MatchPlayerBucket[]

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
  @@index([championId])
  @@index([championId, role, rankTier])
  @@map("match_players")
}

model MatchPlayerCore {
  matchPlayerId        BigInt @id @map("match_player_id")
  kills                Int    @default(0)
  deaths               Int    @default(0)
  assists              Int    @default(0)
  champLevel           Int    @default(0) @map("champ_level")
  champExperience      Int    @default(0) @map("champ_experience")
  goldEarned           Int    @default(0) @map("gold_earned")
  goldSpent            Int    @default(0) @map("gold_spent")
  itemsPurchased       Int    @default(0) @map("items_purchased")
  consumablesPurchased Int    @default(0) @map("consumables_purchased")
  totalMinionsKilled   Int    @default(0) @map("total_minions_killed")
  roleBoundItem        Int    @default(0) @map("role_bound_item")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_core")
}

model MatchPlayerVisions {
  matchPlayerId                   BigInt @id @map("match_player_id")
  detectorWardsPlaced             Int    @default(0) @map("detector_wards_placed")
  visionScore                     Int    @default(0) @map("vision_score")
  visionWardsBoughtInGame         Int    @default(0) @map("vision_wards_bought_in_game")
  wardsKilled                     Int    @default(0) @map("wards_killed")
  wardsPlaced                     Int    @default(0) @map("wards_placed")
  controlWardsPlaced              Int    @default(0) @map("control_wards_placed")
  unseenRecalls                   Int    @default(0) @map("unseen_recalls")
  visionScoreAdvantageLaneOpponent Int   @default(0) @map("vision_score_advantage_lane_opponent")
  wardTakedowns                   Int    @default(0) @map("ward_takedowns")
  wardTakedownsBefore20M          Int    @default(0) @map("ward_takedowns_before_20_m")
  wardsGuarded                    Int    @default(0) @map("wards_guarded")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_visions")
}

model MatchPlayerMatchup {
  matchPlayerId                       BigInt @id @map("match_player_id")
  bountyGold                          Int    @default(0) @map("bounty_gold")
  completeSupportQuestInTime          Int    @default(0) @map("complete_support_quest_in_time")
  deathsByEnemyChamps                 Int    @default(0) @map("deaths_by_enemy_champs")
  earlyLaningPhaseGoldExpAdvantage    Int    @default(0) @map("early_laning_phase_gold_exp_advantage")
  initialCrabCount                    Int    @default(0) @map("initial_crab_count")
  jungleCsBefore10Minutes             Int    @default(0) @map("jungle_cs_before_10_minutes")
  killsNearEnemyTurret                Int    @default(0) @map("kills_near_enemy_turret")
  killsOnOtherLanesEarlyJungleAsLaner Int    @default(0) @map("kills_on_other_lanes_early_jungle_as_laner")
  killsUnderOwnTurret                 Int    @default(0) @map("kills_under_own_turret")
  landSkillShotsEarlyGame             Int    @default(0) @map("land_skill_shots_early_game")
  laneMinionsFirst10Minutes           Int    @default(0) @map("lane_minions_first_10_minutes")
  laningPhaseGoldExpAdvantage         Int    @default(0) @map("laning_phase_gold_exp_advantage")
  maxCsAdvantageOnLaneOpponent        Int    @default(0) @map("max_cs_advantage_on_lane_opponent")
  maxKillDeficit                      Int    @default(0) @map("max_kill_deficit")
  maxLevelLeadLaneOpponent            Int    @default(0) @map("max_level_lead_lane_opponent")
  outnumberedKills                    Int    @default(0) @map("outnumbered_kills")
  quickSoloKills                      Int    @default(0) @map("quick_solo_kills")
  soloKills                           Int    @default(0) @map("solo_kills")
  takedownsAfterGainingLevelAdvantage Int    @default(0) @map("takedowns_after_gaining_level_advantage")
  moreEnemyJungleThanOpponent         Int    @default(0) @map("more_enemy_jungle_than_opponent")
  totalAllyJungleMinionsKilled        Int    @default(0) @map("total_ally_jungle_minions_killed")
  totalEnemyJungleMinionsKilled       Int    @default(0) @map("total_enemy_jungle_minions_killed")
  neutralMinionsKilled                Int    @default(0) @map("neutral_minions_killed")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_matchup")
}

model MatchPlayerObjectives {
  matchPlayerId                          BigInt  @id @map("match_player_id")
  dragonKills                            Int     @default(0) @map("dragon_kills")
  firstBloodKill                         Boolean @default(false) @map("first_blood_kill")
  firstBloodAssist                       Boolean @default(false) @map("first_blood_assist")
  firstTowerKill                         Boolean @default(false) @map("first_tower_kill")
  firstTowerAssist                       Boolean @default(false) @map("first_tower_assist")
  inhibitorKills                         Int     @default(0) @map("inhibitor_kills")
  inhibitorTakedowns                     Int     @default(0) @map("inhibitor_takedowns")
  inhibitorsLost                         Int     @default(0) @map("inhibitors_lost")
  objectivesStolen                       Int     @default(0) @map("objectives_stolen")
  objectivesStolenAssists                Int     @default(0) @map("objectives_stolen_assists")
  turretKills                            Int     @default(0) @map("turret_kills")
  turretTakedowns                        Int     @default(0) @map("turret_takedowns")
  turretsLost                            Int     @default(0) @map("turrets_lost")
  dragonTakedowns                        Int     @default(0) @map("dragon_takedowns")
  earliestBaron                          Int     @default(0) @map("earliest_baron")
  elderDragonKillsWithOpposingSoul       Int     @default(0) @map("elder_dragon_kills_with_opposing_soul")
  elderDragonMultikills                  Int     @default(0) @map("elder_dragon_multikills")
  epicMonsterKillsNearEnemyJungler       Int     @default(0) @map("epic_monster_kills_near_enemy_jungler")
  epicMonsterKillsWithin30SecondsOfSpawn Int     @default(0) @map("epic_monster_kills_within_30_seconds_of_spawn")
  epicMonsterSteals                      Int     @default(0) @map("epic_monster_steals")
  epicMonsterStolenWithoutSmite          Int     @default(0) @map("epic_monster_stolen_without_smite")
  firstTurretKilledTime                  Int     @default(0) @map("first_turret_killed_time")
  riftHeraldTakedowns                    Int     @default(0) @map("rift_herald_takedowns")
  turretPlatesTaken                      Int     @default(0) @map("turret_plates_taken")
  turretsTakenWithRiftHerald             Int     @default(0) @map("turrets_taken_with_rift_herald")
  baronTakedowns                         Int     @default(0) @map("baron_takedowns")
  quickFirstTurret                       Int     @default(0) @map("quick_first_turret")
  soloBaronKills                         Int     @default(0) @map("solo_baron_kills")
  soloTurretsLategame                    Int     @default(0) @map("solo_turrets_lategame")
  takedownOnFirstTurret                  Int     @default(0) @map("takedown_on_first_turret")
  multiTurretRiftHeraldCount             Int     @default(0) @map("multi_turret_rift_herald_count")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_objectives")
}

model MatchPlayerCombats {
  matchPlayerId                 BigInt @id @map("match_player_id")
  damageDealtToBuildings        Int    @default(0) @map("damage_dealt_to_buildings")
  damageDealtToEpicMonsters     Int    @default(0) @map("damage_dealt_to_epic_monsters")
  damageDealtToObjectives       Int    @default(0) @map("damage_dealt_to_objectives")
  damageDealtToTurrets          Int    @default(0) @map("damage_dealt_to_turrets")
  damageSelfMitigated           Int    @default(0) @map("damage_self_mitigated")
  doubleKills                   Int    @default(0) @map("double_kills")
  killingSprees                 Int    @default(0) @map("killing_sprees")
  largestCriticalStrike         Int    @default(0) @map("largest_critical_strike")
  largestKillingSpree           Int    @default(0) @map("largest_killing_spree")
  longestTimeSpentLiving        Int    @default(0) @map("longest_time_spent_living")
  magicDamageDealt              Int    @default(0) @map("magic_damage_dealt")
  magicDamageDealtToChampions   Int    @default(0) @map("magic_damage_dealt_to_champions")
  magicDamageTaken              Int    @default(0) @map("magic_damage_taken")
  pentaKills                    Int    @default(0) @map("penta_kills")
  physicalDamageDealt           Int    @default(0) @map("physical_damage_dealt")
  physicalDamageDealtToChampions Int   @default(0) @map("physical_damage_dealt_to_champions")
  physicalDamageTaken           Int    @default(0) @map("physical_damage_taken")
  quadraKills                   Int    @default(0) @map("quadra_kills")
  totalDamageShieldedOnTeammates Int   @default(0) @map("total_damage_shielded_on_teammates")
  totalDamageTaken              Int    @default(0) @map("total_damage_taken")
  totalHeal                     Int    @default(0) @map("total_heal")
  totalHealsOnTeammates         Int    @default(0) @map("total_heals_on_teammates")
  totalTimeCcDealt              Int    @default(0) @map("total_time_cc_dealt")
  totalUnitsHealed              Int    @default(0) @map("total_units_healed")
  tripleKills                   Int    @default(0) @map("triple_kills")
  trueDamageDealt               Int    @default(0) @map("true_damage_dealt")
  trueDamageDealtToChampions    Int    @default(0) @map("true_damage_dealt_to_champions")
  trueDamageTaken               Int    @default(0) @map("true_damage_taken")
  effectiveHealAndShielding     Int    @default(0) @map("effective_heal_and_shielding")
  timeCcingOthers               Int    @default(0) @map("time_ccing_others")
  enemyChampionImmobilizations  Int    @default(0) @map("enemy_champion_immobilizations")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_combats")
}

model MatchPlayerChallenges {
  matchPlayerId                             BigInt @id @map("match_player_id")
  healFromMapSources                        Int    @default(0) @map("heal_from_map_sources")
  buffsStolen                               Int    @default(0) @map("buffs_stolen")
  dodgeSkillShotsSmallWindow                Int    @default(0) @map("dodge_skill_shots_small_window")
  hadOpenNexus                              Int    @default(0) @map("had_open_nexus")
  immobilizeAndKillWithAlly                 Int    @default(0) @map("immobilize_and_kill_with_ally")
  junglerTakedownsNearDamagedEpicMonster    Int    @default(0) @map("jungler_takedowns_near_damaged_epic_monster")
  killAfterHiddenWithAlly                   Int    @default(0) @map("kill_after_hidden_with_ally")
  killedChampTookFullTeamDamageSurvived     Int    @default(0) @map("killed_champ_took_full_team_damage_survived")
  killsWithHelpFromEpicMonster              Int    @default(0) @map("kills_with_help_from_epic_monster")
  knockEnemyIntoTeamAndKill                 Int    @default(0) @map("knock_enemy_into_team_and_kill")
  mejaisFullStackInTime                     Int    @default(0) @map("mejais_full_stack_in_time")
  multikillsAfterAggressiveFlash            Int    @default(0) @map("multikills_after_aggressive_flash")
  quickCleanse                              Int    @default(0) @map("quick_cleanse")
  saveAllyFromDeath                         Int    @default(0) @map("save_ally_from_death")
  scuttleCrabKills                          Int    @default(0) @map("scuttle_crab_kills")
  skillshotsDodged                          Int    @default(0) @map("skillshots_dodged")
  skillshotsHit                             Int    @default(0) @map("skillshots_hit")
  stealthWardsPlaced                        Int    @default(0) @map("stealth_wards_placed")
  survivedSingleDigitHpCount                Int    @default(0) @map("survived_single_digit_hp_count")
  survivedThreeImmobilizesInFight           Int    @default(0) @map("survived_three_immobilizes_in_fight")
  takedownsBeforeJungleMinionSpawn          Int    @default(0) @map("takedowns_before_jungle_minion_spawn")
  takedownsInAlcove                         Int    @default(0) @map("takedowns_in_alcove")
  takedownsInEnemyFountain                  Int    @default(0) @map("takedowns_in_enemy_fountain")
  tookLargeDamageSurvived                   Int    @default(0) @map("took_large_damage_survived")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@map("match_player_challenges")
}

model MatchPlayerBucket {
  id                           BigInt @id @default(autoincrement())
  matchPlayerId                BigInt @map("match_player_id")
  durationBucket               Int    @map("duration_bucket")
  currentGold                  Int    @default(0) @map("current_gold")
  magicDamageDone              Int    @default(0) @map("magic_damage_done")
  magicDamageDoneToChampion    Int    @default(0) @map("magic_damage_done_to_champion")
  magicDamageTaken             Int    @default(0) @map("magic_damage_taken")
  physicalDamageDone           Int    @default(0) @map("physical_damage_done")
  physicalDamageDoneToChampion Int    @default(0) @map("physical_damage_done_to_champion")
  physicalDamageTaken          Int    @default(0) @map("physical_damage_taken")
  totalDamageDone              Int    @default(0) @map("total_damage_done")
  totalDamageDoneToChampion    Int    @default(0) @map("total_damage_done_to_champion")
  totalDamageTaken             Int    @default(0) @map("total_damage_taken")
  trueDamageDone               Int    @default(0) @map("true_damage_done")
  trueDamageDoneToChampion     Int    @default(0) @map("true_damage_done_to_champion")
  trueDamageTaken              Int    @default(0) @map("true_damage_taken")
  goldPerSecond                Int    @default(0) @map("gold_per_second")
  jungleMinionsKilled          Int    @default(0) @map("jungle_minions_killed")
  level                        Int    @default(0) @map("level")
  minionsKilled                Int    @default(0) @map("minions_killed")
  timeEnemySpentControlled     Int    @default(0) @map("time_enemy_spent_controlled")
  totalGold                    Int    @default(0) @map("total_gold")
  xp                           Int    @default(0) @map("xp")

  matchPlayer MatchPlayer @relation(fields: [matchPlayerId], references: [id], onDelete: Cascade)

  @@unique([matchPlayerId, durationBucket])
  @@index([matchPlayerId])
  @@map("match_player_bucket")
}

// ─── Lean ingest (parallel to legacy matchs / match_players; MVs aggregate ingest_* ) ──

model IngestMatch {
  id                        BigInt    @id @default(autoincrement())
  riotMatchId               String    @unique @map("riot_match_id")
  gameVersion               String    @map("game_version")
  gameDuration              Int       @map("game_duration")
  gameDate                  DateTime? @map("game_date")
  rankTier                  String    @map("rank_tier")
  rankDivision              String    @map("rank_division")
  gameEndedInSurrender      Boolean   @default(false) @map("game_ended_in_surrender")
  gameEndedInEarlySurrender Boolean   @default(false) @map("game_ended_in_early_surrender")
  region                    String

  teams        IngestTeam[]
  matchPlayers IngestMatchPlayer[]

  @@index([gameVersion])
  @@index([rankTier])
  @@index([region])
  @@index([gameVersion, region, rankTier])
  @@index([gameDate])
  @@map("ingest_matchs")
}

model IngestTeam {
  id                   BigInt @id @default(autoincrement())
  matchId              BigInt @map("match_id")
  team                 Int
  rankTier             String @default("UNRANKED") @map("rank_tier")
  win                  Boolean
  teamEarlySurrendered Boolean @default(false) @map("team_early_surrendered")
  baronKills           Int    @default(0) @map("baron_kills")
  baronFirst           Boolean @default(false) @map("baron_first")
  dragonKills          Int    @default(0) @map("dragon_kills")
  dragonFirst          Boolean @default(false) @map("dragon_first")
  towerKills           Int    @default(0) @map("tower_kills")
  towerFirst           Boolean @default(false) @map("tower_first")
  hordeKills           Int    @default(0) @map("horde_kills")
  hordeFirst           Boolean @default(false) @map("horde_first")
  riftHeraldKills      Int    @default(0) @map("rift_herald_kills")
  riftHeraldFirst      Boolean @default(false) @map("rift_herald_first")
  inhibitorKills       Int    @default(0) @map("inhibitor_kills")
  championKills        Int    @default(0) @map("champion_kills")
  firstBlood           Boolean @default(false) @map("first_blood")
  elderKills           Int    @default(0) @map("elder_kills")
  /// Bans from match-v5 team payload: [{ championId, pickOrder }, ...].
  bansJson   Json @default("[]") @map("bans_json")
  /// Drake timeline sequence: [{ drakeType, order, soul }, ...].
  drakesJson Json @default("[]") @map("drakes_json")

  match        IngestMatch         @relation(fields: [matchId], references: [id], onDelete: Cascade)
  matchPlayers IngestMatchPlayer[]

  @@unique([matchId, team])
  @@index([matchId])
  @@map("ingest_teams")
}

model IngestMatchPlayer {
  id             BigInt  @id @default(autoincrement())
  matchId        BigInt  @map("match_id")
  playerId       BigInt  @map("player_id")
  teamId         BigInt  @map("team_id")
  championId     Int     @map("champion_id")
  role           String
  rankTier       String  @default("UNRANKED") @map("rank_tier")
  rankDivision   String? @map("rank_division")
  participantId  Int     @map("participant_id")
  items          Json    @default("[]")
  runes          Int[]   @default([])
  shards         Int[]   @default([])
  summonerSpells Int[]   @default([]) @map("summoner_spells")
  skillOrder     Json?   @map("skill_order")
  win            Boolean @default(false)
  kills          Int     @default(0)
  deaths         Int     @default(0)
  assists        Int     @default(0)
  /// Participant-derived payload (damage, vision, challenges, timeline buckets, etc.).
  stats Json @default("{}")

  match  IngestMatch @relation(fields: [matchId], references: [id], onDelete: Cascade)
  player Player      @relation(fields: [playerId], references: [id], onDelete: Cascade)
  team   IngestTeam  @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([matchId, playerId])
  @@index([matchId])
  @@index([playerId])
  @@index([teamId])
  @@index([championId])
  @@index([championId, role, rankTier])
  @@map("ingest_match_players")
}

/// One row per (UTC day summarized, rank tier without division, champion). Filled daily by poller job.
model ChampionTierDailySnapshot {
  id              BigInt   @id @default(autoincrement())
  dateOfGame      DateTime @db.Date @map("date_of_game")
  rankTier        String   @map("rank_tier")
  role            String   @map("role")
  championId      Int      @map("champion_id")
  games           Int      @default(0)
  wins            Int      @default(0)
  banRatePct      Float    @default(0) @map("ban_rate_pct")
  pickRatePct     Float    @map("pick_rate_pct")

  @@unique([dateOfGame, rankTier, role, championId])
  @@index([championId, dateOfGame(sort: Desc)])
  @@index([rankTier, role, dateOfGame(sort: Desc)])
  @@map("champion_tier_daily_snapshots")
}

model ActivePatch {
