{
  "name": "lelanation-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:no-watch": "tsx src/index.ts",
    "build": "prisma generate && tsc",
    "build:no-generate": "tsc && pm2 restart lelanation-backend",
    "start": "node dist/index.js",
    "sync:data": "tsx src/scripts/syncData.ts",
    "copy:assets": "tsx src/scripts/copyStaticAssets.ts",
    "generate:excluded-items": "tsx src/scripts/generateExcludedItems.ts",
    "typecheck": "tsc --noEmit",
    "test:matchups": "tsx --test src/services/MatchupTierService.test.ts",
    "test:stats": "tsx --test src/utils/statsFormulas.test.ts src/services/TierListService.test.ts src/services/StatsAbandonsService.test.ts src/services/MatchupTierService.test.ts",
    "test:riot-poller": "tsx --test src/utils/rankScore.test.ts src/services/RiotRateLimiter.test.ts src/worker/riotPoller.db.test.ts"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^6.19.2",
    "@prisma/client-runtime-utils": "^7.4.0",
    "axios": "^1.13.2",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "express": "^5.2.1",
    "node-cron": "^4.2.1",
    "pg": "^8.18.0",
    "sharp": "^0.33.5"
  }
}
