{
  "name": "lelanation-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:no-watch": "tsx src/index.ts",
    "build": "prisma generate && tsc",
    "build:no-generate": "tsc && pm2 restart lelanation-backend",
    "start": "node dist/index.js",
    "sync:data": "tsx src/scripts/syncData.ts",
    "copy:assets": "tsx src/scripts/copyStaticAssets.ts",
    "generate:excluded-items": "tsx src/scripts/generateExcludedItems.ts",
    "typecheck": "tsc --noEmit",
    "test:matchups": "tsx --test src/services/MatchupTierService.test.ts",
    "test:stats": "tsx --test src/utils/statsFormulas.test.ts src/utils/statsMvBanAggregate.test.ts src/utils/statShardLegacyMerge.test.ts src/services/TierListService.test.ts src/services/StatsAbandonsService.test.ts src/services/MatchupTierService.test.ts src/services/BalanceRulesService.test.ts src/services/StatsBalanceService.test.ts",
    "test:riot-poller": "tsx --test src/utils/rankScore.test.ts src/services/RiotRateLimiter.test.ts src/worker/matchIngestQueue.test.ts src/worker/ingestMatchLean.db.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "drizzle:statistiques:migrate": "drizzle-kit migrate --config=drizzle.statistiques.config.ts",
    "drizzle:statistiques:studio": "drizzle-kit studio --config=drizzle.statistiques.config.ts",
    "script:puuid-migration": "tsx src/worker/runScript.ts puuid-migration",
    "script:league-xp": "tsx src/worker/runScript.ts league-xp",
    "script:backfill-agg": "tsx src/scripts/backfillAggFromIngest.ts",
    "script:backfill-agg-starter-set": "tsx src/scripts/backfillAggItemStarterSetFromRaw.ts",
    "script:backfill-agg-objective-outcome": "tsx src/scripts/backfillAggObjectiveOutcomeFromAgg.ts",
    "script:backfill-ingest-player-extras": "tsx src/scripts/backfillIngestPlayerExtras.ts",
    "script:backfill-raw-participants": "tsx src/scripts/backfillMatchIngestRawParticipants.ts",
    "script:repair-missing-ranks": "tsx src/scripts/repairMissingRanks.ts",
    "script:repair-players-metadata": "tsx src/scripts/repairPlayersMetadata.ts",
    "script:recompute-ingest-ranks": "tsx src/scripts/recomputeIngestRanks.ts",
    "script:global-rank-recovery": "tsx src/scripts/runGlobalRankRecovery.ts",
    "script:verify-agg-parity": "tsx src/scripts/verifyAggParity.ts",
    "script:reclassify-stale-tracked": "tsx src/scripts/reclassifyStaleTrackedMatches.ts",
    "script:riot-live-test": "tsx src/scripts/testRiotApiKeyLive.ts",
    "script:copy-stats-statistiques": "tsx src/scripts/copyStatsToStatistiquesDb.ts",
    "script:sync-players-statistiques": "tsx src/scripts/copyStatsToStatistiquesDb.ts --sync-players-only",
    "test:rate-limiter": "vitest run tests/rate-limiter.test.ts"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.10",
    "prisma": "^6.19.2",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.3.0",
    "@prisma/client": "^6.19.3",
    "@prisma/client-runtime-utils": "^7.4.0",
    "bottleneck": "^2.19.5",
    "bullmq": "^5.76.8",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "p-limit": "^3.1.0",
    "pg": "^8.18.0",
    "postgres": "^3.4.9",
    "sharp": "^0.33.5"
  }
}
