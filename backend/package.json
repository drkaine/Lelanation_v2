{
  "name": "lelanation-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:no-watch": "tsx src/index.ts",
    "build": "tsc",
    "build:no-generate": "tsc && pm2 restart lelanation-backend",
    "start": "node dist/index.js",
    "seed:matchup-guides": "tsx src/scripts/seedMatchupGuides.ts",
    "sync:matchup-guide-builds": "tsx src/scripts/syncMatchupGuideBuilds.ts",
    "script:test-discord-sync": "tsx src/scripts/testDiscordSyncNotifications.ts",
    "build:theorycraft-data": "tsx src/scripts/buildTheorycraftData.ts",
    "copy:assets": "tsx src/scripts/copyStaticAssets.ts",
    "generate:excluded-items": "tsx src/scripts/generateExcludedItems.ts",
    "typecheck": "tsc --noEmit",
    "test:matchups": "tsx --test src/services/MatchupTierService.test.ts",
    "test:stats": "DATABASE_URL=postgresql://lelanation:lelanation@localhost:5434/lelanation_statistiques tsx --test src/utils/statsFormulas.test.ts src/utils/statsMvBanAggregate.test.ts src/utils/statShardLegacyMerge.test.ts src/services/TierListService.test.ts src/services/StatsAbandonsService.test.ts src/services/MatchupTierService.test.ts src/services/BalanceRulesService.test.ts src/services/StatsBalanceService.test.ts",
    "test:riot-poller": "tsx --test src/utils/rankScore.test.ts src/services/RiotRateLimiter.test.ts",
    "drizzle:statistiques:migrate": "drizzle-kit migrate --config=drizzle.statistiques.config.ts",
    "drizzle:statistiques:studio": "drizzle-kit studio --config=drizzle.statistiques.config.ts",
    "script:puuid-migration": "tsx src/worker/runScript.ts puuid-migration",
    "script:league-xp": "tsx src/worker/runScript.ts league-xp",
    "script:riot-live-test": "tsx src/scripts/testRiotApiKeyLive.ts",
    "script:merge-objective-histogram-global": "tsx src/scripts/runMergeObjectiveHistogramGlobal.ts",
    "test:rate-limiter": "vitest run tests/rate-limiter.test.ts",
    "test:gateway": "vitest run --config vitest.config.ts",
    "test:gateway:integration": "vitest run --config vitest.integration.config.ts",
    "test:gateway:throughput": "vitest run --config vitest.integration.config.ts tests/riot-gateway/integration/liveThroughput.test.ts",
    "test:precommit": "npm run test:gateway && npm run test:poller:unit",
    "test:poller:unit": "vitest run --config vitest.poller.unit.config.ts",
    "test:poller:e2e": "vitest run --config vitest.poller.e2e.config.ts",
    "test:poller:integration": "vitest run --config vitest.poller.integration.config.ts",
    "test:poller:stability": "vitest run --config vitest.poller.stability.config.ts",
    "test:poller:stability:live": "STABILITY_USE_LIVE_API=true STABILITY_DURATION_MINUTES=20 vitest run --config vitest.poller.stability.config.ts --testNamePattern soak",
    "test:poller:stability:live:quick": "STABILITY_USE_LIVE_API=true STABILITY_DURATION_MINUTES=5 vitest run --config vitest.poller.stability.config.ts --testNamePattern soak",
    "test:orchestration:unit": "vitest run --config vitest.orchestration.config.ts",
    "test:orchestration:e2e": "vitest run --config vitest.orchestration.e2e.config.ts",
    "test:orchestration:integration": "vitest run --config vitest.orchestration.integration.config.ts",
    "test:tuner": "vitest run --config vitest.tuner.config.ts",
    "test:tuner:e2e": "vitest run --config vitest.tuner.e2e.config.ts",
    "test:observability": "vitest run --config vitest.observability.config.ts",
    "test:services": "vitest run --config vitest.services.config.ts",
    "test:aggregation:integration": "vitest run --config vitest.aggregation.integration.config.ts",
    "test:aggregation:setup-db": "PGPASSWORD=lelanation psql -h localhost -p 5434 -U lelanation -d postgres -c \"DROP DATABASE IF EXISTS lelanation_stats_test;\" -c \"CREATE DATABASE lelanation_stats_test OWNER lelanation;\" && PGPASSWORD=lelanation pg_dump -h localhost -p 5434 -U lelanation -d lelanation_statistiques --schema-only --no-owner --no-privileges | PGPASSWORD=lelanation psql -h localhost -p 5434 -U lelanation -d lelanation_stats_test",
    "test:poller:all": "npm run test:poller:unit && npm run test:poller:e2e && npm run test:orchestration:unit && npm run test:orchestration:e2e && npm run test:tuner",
    "test:all": "npm run test:gateway && npm run test:poller:all && npm run test:tuner:e2e && npm run test:observability && npm run test:orchestration:integration",
    "test:poller": "npm run test:poller:all",
    "seed:eu": "tsx scripts/seed-eu-players.ts",
    "scrape:patch": "tsx src/scripts/scrapePatch.ts",
    "scrape:patches": "tsx src/scripts/scrapeAllPatches.ts",
    "scrape:patches:rescrape-below": "tsx src/scripts/scrapeAllPatches.ts 16.1 --force --below 16.11",
    "publish:patches": "tsx src/scripts/publishPatchNotes.ts",
    "backfill:patch-notes-stats": "tsx src/scripts/backfillPatchNotesStats.ts",
    "flag:builds-patch-stale": "tsx src/scripts/flagBuildsPatchStale.ts",
    "flag:builds-patch-stale:all": "tsx src/scripts/flagBuildsPatchStale.ts --all",
    "script:sync-champion-regions": "tsx src/scripts/syncChampionRegions.ts",
    "test:scraper": "vitest run --config vitest.scraper.config.ts"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.20.0",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "bullmq": "^5.76.8",
    "cheerio": "^1.2.0",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "p-limit": "^3.1.0",
    "pg": "^8.18.0",
    "pino": "^10.3.1",
    "pino-pretty": "^11.3.0",
    "playwright": "^1.61.1",
    "postgres": "^3.4.9",
    "sharp": "^0.33.5",
    "undici": "^6.21.0"
  }
}
