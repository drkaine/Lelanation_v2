{
  "name": "lelanation-backend",
  "version": "1.0.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "dev:no-watch": "tsx src/index.ts",
    "build": "tsc",
    "build:no-generate": "tsc && pm2 restart lelanation-backend",
    "start": "node dist/index.js",
    "sync:data": "tsx src/scripts/syncData.ts",
    "build:theorycraft-data": "tsx src/scripts/buildTheorycraftData.ts",
    "copy:assets": "tsx src/scripts/copyStaticAssets.ts",
    "generate:excluded-items": "tsx src/scripts/generateExcludedItems.ts",
    "typecheck": "tsc --noEmit",
    "test:matchups": "tsx --test src/services/MatchupTierService.test.ts",
    "test:stats": "DATABASE_URL=postgresql://lelanation:lelanation@localhost:5434/lelanation_statistiques tsx --test src/utils/statsFormulas.test.ts src/utils/statsMvBanAggregate.test.ts src/utils/statShardLegacyMerge.test.ts src/services/TierListService.test.ts src/services/StatsAbandonsService.test.ts src/services/MatchupTierService.test.ts src/services/BalanceRulesService.test.ts src/services/StatsBalanceService.test.ts",
    "test:riot-poller": "tsx --test src/utils/rankScore.test.ts src/services/RiotRateLimiter.test.ts",
    "drizzle:statistiques:migrate": "drizzle-kit migrate --config=drizzle.statistiques.config.ts",
    "drizzle:statistiques:studio": "drizzle-kit studio --config=drizzle.statistiques.config.ts",
    "script:puuid-migration": "tsx src/worker/runScript.ts puuid-migration",
    "script:league-xp": "tsx src/worker/runScript.ts league-xp",
    "script:riot-live-test": "tsx src/scripts/testRiotApiKeyLive.ts",
    "script:merge-objective-histogram-global": "tsx src/scripts/runMergeObjectiveHistogramGlobal.ts",
    "test:rate-limiter": "vitest run tests/rate-limiter.test.ts"
  },
  "devDependencies": {
    "@types/compression": "^1.8.1",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.0.9",
    "@types/node-cron": "^3.0.11",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "vitest": "^4.1.6"
  },
  "dependencies": {
    "bottleneck": "^2.19.5",
    "bullmq": "^5.76.8",
    "compression": "^1.8.1",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "node-cron": "^4.2.1",
    "p-limit": "^3.1.0",
    "pg": "^8.18.0",
    "postgres": "^3.4.9",
    "sharp": "^0.33.5"
  }
}
