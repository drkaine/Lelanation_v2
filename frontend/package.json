{
  "name": "frontend",
  "type": "module",
  "private": true,
  "scripts": {
    "build:no-restart": "node scripts/generate-og-default.mjs && node scripts/generate-champion-names.mjs && nuxt build",
    "build": "npm run build:no-restart",
    "build:restart": "npm run build:no-restart && pm2 restart lelanation-frontend",
    "generate:webp": "node scripts/generate-lelariva-webp.mjs",
    "generate:og": "node scripts/generate-og-default.mjs",
    "generate:champion-names": "node scripts/generate-champion-names.mjs",
    "dev": "nuxt dev",
    "generate": "nuxt generate",
    "preview": "nuxt preview",
    "postinstall": "nuxt prepare",
    "typecheck": "vue-tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@iconify-json/mdi": "^1.2.3",
    "@lelanation/builds-stats": "*",
    "@lelanation/builds-ui": "*",
    "@lelanation/shared-theme": "*",
    "@lelanation/shared-types": "*",
    "@nuxt/icon": "^2.2.1",
    "@nuxtjs/i18n": "^10.2.1",
    "@nuxtjs/robots": "^5.7.0",
    "@nuxtjs/sitemap": "^7.6.0",
    "@pinia/nuxt": "^0.11.3",
    "@unovis/ts": "^1.6.5",
    "html-to-image": "^1.11.13",
    "nuxt": "^4.1.3",
    "nuxt-charts": "^2.1.4",
    "pinia": "^3.0.4",
    "playwright": "^1.50.1",
    "sharp": "^0.33.5",
    "vue": "^3.5.26",
    "vue-matomo": "^4.2.0",
    "vue-router": "^4.6.4"
  },
  "devDependencies": {
    "@nuxtjs/eslint-config-typescript": "^12.1.0",
    "@nuxtjs/tailwindcss": "^6.14.0",
    "@types/node": "^25.1.0",
    "autoprefixer": "^10.4.23",
    "eslint": "^8.57.1",
    "eslint-config-prettier": "^10.1.8",
    "postcss": "^8.5.6",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "tailwindcss": "^3.4.19",
    "vite-tsconfig-paths": "^6.0.5",
    "vue-tsc": "^3.2.4"
  }
}
