{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lelanation",
  "version": "1.1.0",
  "identifier": "fr.lelanation.companion",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "create": false,
        "label": "main",
        "title": "Lelanation Companion",
        "width": 1100,
        "height": 780
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/drkaine/Lelanation_v2/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDlCMUU4NTE1N0IyNzBGQjIKUldTeUR5ZDdGWVVlbStlNGFUejBrMk5FZjNNS3VubDVHazFoTDE1Zm5naldScExhUjR5eC9MUS8K"
    }
  },
  "bundle": {
    "active": true,
    "createUpdaterArtifacts": true,
    "targets": "all",
    "publisher": "Darkaine",
    "copyright": "© 2026 Darkaine / Lelanation",
    "category": "Utility",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "displayLanguageSelector": false,
        "installerHooks": "windows/installer-hooks.nsh"
      }
    }
  }
}
